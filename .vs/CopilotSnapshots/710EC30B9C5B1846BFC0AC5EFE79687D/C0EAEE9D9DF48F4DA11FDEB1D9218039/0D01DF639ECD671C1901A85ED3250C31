@inject IUserService CurrentUser

@{
    ViewData["Title"] = "Home";
    Layout = "_Layout";
}

<section class="content">
    <div class="container-fluid">

        <div class="card">
            <div class="card-body text-center">

                <div class="p-5 mb-4 rounded-4 text-white text-center"
                     style="background: linear-gradient(135deg, #0d6efd, #6610f2);">

                    <h1 class="fw-bold display-5">
                        👋 Xin chào
                        @if (CurrentUser.IsAuthenticated)
                        {
                            <strong>@(CurrentUser.Name)</strong>
                        }
                        else
                        {

                        }
                    </h1>

                    <p class="mt-3 fs-5">
                        Are you ready to conquer new jobs?
                    </p>
                </div>

                @if (!CurrentUser.IsAuthenticated)
                {
                    <a href="/auth/login" class="btn btn-lg btn-primary">
                        Get started
                    </a>
                }

            </div>
        </div>

        <div class="card">
            <div class="card-body">

                <div class="d-flex justify-content-between">
                    <div class="flex-fill">
                        <form method="get" class="card p-3 mb-4 shadow-sm">
                        </form>
                    </div>
                </div>

                <div class="mt-4">
                </div>
            </div>
        </div>

    </div>
</section>


@section Scripts {
    <script>
        $(document).ready(() => {
            
        });
    </script>
}
