@using BusinessObjects.Common
@using BusinessObjects.DTOs
@model PaginateResult<AdminPaymentDto>

@{
    ViewBag.Title = "Lịch sử thanh toán";
    Layout = "_Layout";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Lịch sử thanh toán hệ thống</h2>
            <p class="text-muted mb-0">Quản trị viên theo dõi tất cả các giao dịch thanh toán dự án giữa Employer và Freelancer</p>
        </div>
    </div>

    <!-- Search Form -->
    <form method="get" class="card p-3 mb-4 shadow-sm">
        <div class="row g-3">
            <div class="col-md-10">
                <input type="text" name="keyword" value="@ViewData["Keyword"]" class="form-control" placeholder="Tìm kiếm theo mã giao dịch, tên công việc, nhà tuyển dụng hoặc freelancer..." />
            </div>
            <div class="col-md-2 d-grid">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-search"></i> Tìm kiếm
                </button>
            </div>
        </div>
    </form>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-4">Mã giao dịch</th>
                        <th>Công việc</th>
                        <th>Nhà tuyển dụng</th>
                        <th>Freelancer</th>
                        <th>Số tiền (VNĐ)</th>
                        <th>Phương thức</th>
                        <th>Thời gian</th>
                        <th class="text-end pe-4">Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Items != null && Model.Items.Any())
                    {
                        @foreach (var payment in Model.Items)
                        {
                            <tr>
                                <td class="ps-4">
                                    <span class="text-monospace fw-bold text-secondary">@payment.TransactionCode</span>
                                </td>
                                <td>
                                    <div class="fw-semibold text-dark">@payment.JobTitle</div>
                                </td>
                                <td>
                                    <div>@payment.EmployerName</div>
                                </td>
                                <td>
                                    <div>@payment.FreelancerName</div>
                                </td>
                                <td class="fw-bold text-success">
                                    @payment.Amount.ToString("N0") đ
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark border">@payment.PaymentMethod</span>
                                </td>
                                <td>
                                    <div class="small">
                                        <strong>Tạo:</strong> @payment.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                    </div>
                                    @if (payment.PaidAt.HasValue)
                                    {
                                        <div class="small text-muted">
                                            <strong>Thanh toán:</strong> @payment.PaidAt.Value.ToString("dd/MM/yyyy HH:mm")
                                        </div>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    @if (payment.Status.ToUpper() == "PAID" || payment.Status.ToUpper() == "SUCCESS")
                                    {
                                        <span class="badge bg-success"><i class="bi bi-check-circle"></i> Đã thanh toán</span>
                                    }
                                    else if (payment.Status.ToUpper() == "FAILED")
                                    {
                                        <span class="badge bg-danger"><i class="bi bi-x-circle"></i> Thất bại</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark"><i class="bi bi-clock"></i> Chờ thanh toán</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5 text-muted">
                                <i class="bi bi-wallet2 fs-2 d-block mb-2"></i>
                                Không tìm thấy lịch sử thanh toán nào.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if (Model != null && Model.TotalItems > Model.PageSize)
        {
            var totalPages = (int)Math.Ceiling((double)Model.TotalItems / Model.PageSize);
            <div class="card-footer bg-white d-flex justify-content-between align-items-center py-3 border-top">
                <span class="text-muted small">Hiển thị trang @Model.PageNumber / @totalPages (@Model.TotalItems kết quả)</span>
                <nav>
                    <ul class="pagination pagination-sm mb-0">
                        @for (int i = 1; i <= totalPages; i++)
                        {
                            <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                <a class="page-link" href="?keyword=@ViewData["Keyword"]&page=@i">@i</a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>
