@{
    ViewData["Title"] = "Bảng thống kê Admin";
    Layout = "_Layout";
}

<div class="container-fluid py-4">

    <!-- PAGE HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Bảng thống kê</h2>
            <p class="text-muted mb-0">
                Tổng quan số liệu thống kê và hoạt động hệ thống
            </p>
        </div>

        <div>
            <select id="dashboardRange" class="form-select">
                <option value="Today">Hôm nay</option>
                <option value="ThisWeek">Tuần này</option>
                <option value="ThisMonth" selected>Tháng này</option>
                <option value="ThisYear">Năm nay</option>
            </select>
        </div>
    </div>

    <!-- OVERVIEW CARDS -->
    <div class="row g-4 mb-4">

        <div class="col-md-3">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body">
                    <div id="usersLoading">
                        <h6 class="text-muted">Tổng người dùng</h6>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="skeleton skeleton-text"></div>
                                <div class="skeleton skeleton-sm"></div>
                            </div>
                            <div class="col-md-6">
                                <div class="skeleton skeleton-chart h-100"></div>
                            </div>
                        </div>
                    </div>

                    <div id="usersContent" class="d-none">

                        <h6 class="text-muted">Tổng người dùng</h6>
                        <div class="row">
                            <div class="col-md-6">
                                <h2 id="totalUsers" class="fw-bold">0</h2>

                                <small class="text-success" id="newUsers">
                                    +0 người dùng mới
                                </small>
                            </div>
                            <div class="col-md-6">
                                <canvas id="miniChartUsers"></canvas>
                            </div>
                        </div>

                    </div>

                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body">

                    <div id="jobsLoading">
                        <h6 class="text-muted">Tổng việc làm</h6>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="skeleton skeleton-text"></div>
                                <div class="skeleton skeleton-sm"></div>
                            </div>
                            <div class="col-md-6">
                                <div class="skeleton skeleton-chart h-100"></div>
                            </div>
                        </div>
                    </div>

                    <div id="jobsContent" class="d-none">
                        <h6 class="text-muted">Tổng việc làm</h6>
                        <div class="row">
                            <div class="col-md-6">
                                <h2 id="totalJobs" class="fw-bold">0</h2>

                                <small class="text-success" id="activeJobs">
                                    0 việc hoạt động
                                </small>
                            </div>
                            <div class="col-md-6">
                                <canvas id="miniChartJobs"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body">

                    <div id="applicationsLoading">
                        <h6 class="text-muted">Đơn ứng tuyển</h6>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="skeleton skeleton-text"></div>
                                <div class="skeleton skeleton-sm"></div>
                            </div>
                            <div class="col-md-6">
                                <div class="skeleton skeleton-chart h-100"></div>
                            </div>
                        </div>
                    </div>

                    <div id="applicationsContent" class="d-none">
                        <h6 class="text-muted">Đơn ứng tuyển</h6>
                        <div class="row">
                            <div class="col-md-6">
                                <h2 id="totalApplications" class="fw-bold">0</h2>

                                <small class="text-success" id="matchRate">
                                    0% tỷ lệ khớp
                                </small>
                            </div>
                            <div class="col-md-6">
                                <canvas id="miniChartApplications"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body">

                    <div id="revenueLoading">
                        <h6 class="text-muted">Doanh thu hệ thống</h6>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="skeleton skeleton-text"></div>
                                <div class="skeleton skeleton-sm"></div>
                            </div>
                            <div class="col-md-6">
                                <div class="skeleton skeleton-chart h-100"></div>
                            </div>
                        </div>
                    </div>

                    <div id="revenueContent" class="d-none">
                        <h6 class="text-muted">Doanh thu hệ thống</h6>
                        <div class="row">
                            <div class="col-md-6">
                                <h2 id="totalRevenue" class="fw-bold" style="font-size: 1.6rem; white-space: nowrap;">0</h2>

                                <small class="text-success" id="monthlyRevenue">
                                    0 đ trong kỳ
                                </small>
                            </div>
                            <div class="col-md-6">
                                <canvas id="miniChartRevenue"></canvas>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>

    </div>

    <!-- CHARTS -->
    <div class="row g-4 mb-4">

        <!-- USER GROWTH -->
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white border-0 pt-3">
                    <h5 class="mb-0 fw-bold">Tăng trưởng người dùng</h5>
                </div>

                <div class="card-body">

                    <div id="userGrowthLoading"
                          class="skeleton skeleton-chart">
                    </div>

                    <canvas id="userGrowthContent"
                            height="120"
                            class="d-none">
                    </canvas>

                </div>
            </div>
        </div>

        <!-- JOB GROWTH -->
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white border-0 pt-3">
                    <h5 class="mb-0 fw-bold">Thống kê việc làm & ứng tuyển</h5>
                </div>

                <div class="card-body">

                    <div id="jobGrowthLoading"
                          class="skeleton skeleton-chart">
                    </div>

                    <canvas id="jobGrowthContent"
                            height="120"
                            class="d-none">
                    </canvas>

                </div>
            </div>
        </div>

    </div>

    <!-- TABLES -->
    <div class="row g-4">

        <!-- RECENT USERS -->
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white border-0 pt-3">
                    <h5 class="mb-0 fw-bold">Người dùng mới đăng ký</h5>
                </div>

                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th class="ps-4">Họ và tên</th>
                                <th>Vai trò</th>
                                <th class="pe-4 text-end">Ngày tham gia</th>
                            </tr>
                        </thead>
                        <tbody id="recentUsersLoading">

                            <tr>
                                <td colspan="3">

                                    <div class="skeleton skeleton-row"></div>
                                    <div class="skeleton skeleton-row"></div>
                                    <div class="skeleton skeleton-row"></div>

                                </td>
                            </tr>

                        </tbody>

                        <tbody id="recentUsersContent" class="d-none">
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- RECENT JOBS -->
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white border-0 pt-3">
                    <h5 class="mb-0 fw-bold">Công việc mới đăng</h5>
                </div>

                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th class="ps-4">Tiêu đề</th>
                                <th>Nhà tuyển dụng</th>
                                <th class="pe-4 text-end">Ngày tạo</th>
                            </tr>
                        </thead>

                        <tbody id="recentJobsLoading">

                            <tr>
                                <td colspan="3">

                                    <div class="skeleton skeleton-row"></div>
                                    <div class="skeleton skeleton-row"></div>
                                    <div class="skeleton skeleton-row"></div>

                                </td>
                            </tr>

                        </tbody>

                        <tbody id="recentJobsContent" class="d-none">
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>

</div>

@section Scripts {

    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/js/pages/admin/dashboard.js" asp-append-version="true"></script>
}