@model List<WalletUserDto>
@using BusinessObjects.DTOs

@{
    ViewData["Title"] = "Wallet Management";
    Layout = "_Layout";
}

<div class="card">
    <div class="card-header">
        <div class="d-flex justify-content-between align-items-center">
            <h3><i class="bi bi-wallet2"></i> Wallet Management</h3>
        </div>

        <!-- Search -->
        <form method="get" class="card p-3 mb-0 mt-3 shadow-sm">
            <div class="row g-3">
                <div class="col-md-10">
                    <input type="text" name="keyword" value="@ViewBag.Keyword"
                           class="form-control" placeholder="Search by name or email..." />
                </div>
                <div class="col-md-2 d-grid">
                    <button class="btn btn-primary">
                        <i class="bi bi-search"></i> Search
                    </button>
                </div>
            </div>
        </form>
    </div>

    <div class="card-body">
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <h5 class="text-muted">No users found</h5>
            </div>
        }
        else
        {
            <table class="table table-bordered table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th width="60">#</th>
                        <th>Full Name</th>
                        <th>Email</th>
                        <th width="120">Role</th>
                        <th width="100">Status</th>
                        <th width="180" class="text-end">Balance (VNĐ)</th>
                        <th width="200" class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var (item, index) in Model.Select((v, i) => (v, i)))
                    {
                        <tr>
                            <td>@(index + 1)</td>
                            <td><strong>@item.FullName</strong></td>
                            <td>@item.Email</td>
                            <td>
                                <span class="badge @(item.Role == "EMPLOYER" ? "bg-primary" : "bg-success")">
                                    @item.Role
                                </span>
                            </td>
                            <td>
                                <span class="badge @(item.IsActive ? "bg-success" : "bg-secondary")">
                                    @(item.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>
                            <td class="text-end fw-bold">
                                @item.Balance.ToString("N0")
                            </td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-success"
                                        onclick="openAdjustModal(@item.UserId, '@item.FullName', 'deposit')">
                                    <i class="bi bi-plus-circle"></i> Deposit
                                </button>
                                <button class="btn btn-sm btn-danger"
                                        onclick="openAdjustModal(@item.UserId, '@item.FullName', 'withdraw')">
                                    <i class="bi bi-dash-circle"></i> Withdraw
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

<!-- Modal Nap/Rut tien -->
<div class="modal fade" id="adjustModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="adjustForm" method="post">
                <div class="modal-header">
                    <h5 class="modal-title" id="adjustModalTitle">Adjust Balance</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="UserId" id="adjustUserId" />
                    <div class="mb-3">
                        <label class="form-label fw-bold">User</label>
                        <p id="adjustUserName" class="form-control-plaintext"></p>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Amount (VNĐ)</label>
                        <input type="number" name="Amount" class="form-control"
                               min="1000" step="1000" required
                               placeholder="Enter amount..." />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Description (optional)</label>
                        <textarea name="Description" class="form-control" rows="2"
                                  placeholder="Reason for adjustment..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn" id="adjustSubmitBtn">Confirm</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openAdjustModal(userId, userName, action) {
            document.getElementById('adjustUserId').value = userId;
            document.getElementById('adjustUserName').textContent = userName;

            const form = document.getElementById('adjustForm');
            const title = document.getElementById('adjustModalTitle');
            const btn = document.getElementById('adjustSubmitBtn');

            if (action === 'deposit') {
                form.action = '/finance/deposit';
                title.textContent = 'Deposit Money for ' + userName;
                btn.textContent = 'Deposit';
                btn.className = 'btn btn-success';
            } else {
                form.action = '/finance/withdraw';
                title.textContent = 'Withdraw Money from ' + userName;
                btn.textContent = 'Withdraw';
                btn.className = 'btn btn-danger';
            }

            var modal = new bootstrap.Modal(document.getElementById('adjustModal'));
            modal.show();
        }
    </script>
}
