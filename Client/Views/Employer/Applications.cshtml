@model List<BusinessObjects.DTOs.EmployerApplicationDto>
@{
    ViewBag.Title = "Quản lý đơn ứng tuyển";
    Layout = "_Layout";
}

<div class="container my-5" style="font-family: 'Inter', sans-serif;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">Đơn Ứng Tuyển Gần Đây</h2>
            <p class="text-muted">Quản lý và duyệt hồ sơ Freelancer ứng tuyển dự án của bạn</p>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-4">Tên Freelancer</th>
                        <th>Dự án ứng tuyển</th>
                        <th>Ngày nộp</th>
                        <th>Trạng thái</th>
                        <th>Thư giới thiệu</th>
                        <th class="text-end pe-4">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var app in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <a href="/employer/freelancer-profile/@app.FreelancerProfileId" class="fw-bold text-primary">@app.FreelancerName</a>
                                </td>
                                <td>
                                    <div class="fw-semibold">@app.JobTitle</div>
                                </td>
                                <td>@app.AppliedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    @if (app.Status == "PENDING")
                                    {
                                        <span class="badge bg-warning text-dark px-3 py-2 rounded-pill">Đang chờ</span>
                                    }
                                    else if (app.Status == "ACCEPTED" || app.Status == "IN_PROGRESS")
                                    {
                                        <span class="badge bg-info px-3 py-2 rounded-pill">Đang thực hiện</span>
                                    }
                                    else if (app.Status == "COMPLETED")
                                    {
                                        <span class="badge bg-success px-3 py-2 rounded-pill">Hoàn thành</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger px-3 py-2 rounded-pill">Từ chối</span>
                                    }
                                </td>
                                <td>
                                    <button class="btn btn-sm btn-outline-secondary" 
                                            onclick="showCoverLetter('@app.FreelancerName', '@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(app.CoverLetter))')">
                                        <i class="bi bi-eye"></i> Xem thư
                                    </button>
                                </td>
                                <td class="text-end pe-4">
                                    @if (app.Status == "PENDING")
                                    {
                                        <form asp-action="Approve" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@app.Id" />
                                            <input type="hidden" name="status" value="2" />
                                            <button type="submit" class="btn btn-sm btn-success me-1">
                                                <i class="bi bi-check-lg"></i> Nhận
                                            </button>
                                        </form>
                                        <form asp-action="Approve" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@app.Id" />
                                            <input type="hidden" name="status" value="3" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                <i class="bi bi-x-lg"></i> Từ chối
                                            </button>
                                        </form>
                                    }
                                    else if (app.Status == "ACCEPTED" || app.Status == "IN_PROGRESS")
                                    {
                                        <form asp-action="Complete" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@app.Id" />
                                            <button type="submit" class="btn btn-sm btn-primary"
                                                    onclick="return confirm('Xác nhận hoàn thành dự án? Tiền từ ví của bạn sẽ được chuyển cho Freelancer (sau khi khấu trừ 10% hoa hồng hệ thống).')">
                                                <i class="bi bi-check-circle"></i> Hoàn thành
                                            </button>
                                        </form>
                                    }
                                    else if (app.Status == "COMPLETED")
                                    {
                                        if (!app.IsReviewed)
                                        {
                                            <button class="btn btn-sm btn-warning" onclick="openReviewModal(@app.FreelancerProfileId, '@app.FreelancerName')">
                                                <i class="bi bi-star"></i> Đánh giá
                                            </button>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">Đã đánh giá</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Đã hoàn tất</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox fs-1 d-block mb-3 opacity-50"></i>
                                Chưa có đơn ứng tuyển nào được nộp cho các dự án của bạn.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal xem Cover Letter -->
<div class="modal fade" id="coverLetterModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold" id="modalTitle">Thư giới thiệu</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="modalBody" style="white-space: pre-line; line-height: 1.6;">
            </div>
        </div>
    </div>
</div>

<!-- Review Modal -->
<div class="modal fade" id="reviewModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="CreateReview" asp-controller="Employer" method="post">
                <div class="modal-header">
                    <h5 class="modal-title">Đánh giá Freelancer</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="RevieweeId" id="revieweeId" />
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold">Freelancer</label>
                        <p id="revieweeName" class="form-control-plaintext"></p>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold">Số sao (1-5)</label>
                        <select name="Rating" class="form-select" required>
                            <option value="5" selected>5 ⭐⭐⭐⭐⭐ (Xuất sắc)</option>
                            <option value="4">4 ⭐⭐⭐⭐ (Tốt)</option>
                            <option value="3">3 ⭐⭐⭐ (Khá)</option>
                            <option value="2">2 ⭐⭐ (Trung bình)</option>
                            <option value="1">1 ⭐ (Kém)</option>
                        </select>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold">Nhận xét chi tiết</label>
                        <textarea name="Comment" class="form-control" rows="3" required placeholder="Nhập cảm nhận của bạn về chất lượng công việc của Freelancer này..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary">Gửi đánh giá</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showCoverLetter(name, content) {
            document.getElementById('modalTitle').innerText = 'Thư giới thiệu của ' + name;
            document.getElementById('modalBody').innerText = content;
            var myModal = new bootstrap.Modal(document.getElementById('coverLetterModal'));
            myModal.show();
        }

        function openReviewModal(freelancerId, name) {
            document.getElementById('revieweeId').value = freelancerId;
            document.getElementById('revieweeName').textContent = name;
            var modal = new bootstrap.Modal(document.getElementById('reviewModal'));
            modal.show();
        }
    </script>
}
