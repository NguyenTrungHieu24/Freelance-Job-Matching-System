@model List<BusinessObjects.DTOs.EmployerApplicationDto>
@{
    ViewBag.Title = "Quản lý đơn ứng tuyển";
    Layout = "_Layout";
}

<div class="container my-5" style="font-family: 'Inter', sans-serif;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">Đơn Ứng Tuyển Gần Đây</h2>
            <p class="text-muted">Quản lý và duyệt hồ sơ Freelancer ứng tuyển dự án của bạn</p>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-4">Tên Freelancer</th>
                        <th>Dự án ứng tuyển</th>
                        <th>Ngày nộp</th>
                        <th>Trạng thái</th>
                        <th>Thư giới thiệu</th>
                        <th>CV</th>
                        <th class="text-end pe-4">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var app in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-primary">
                                        @app.FreelancerName
                                        <a href="javascript:void(0)" class="text-danger ms-2 small fw-normal" onclick="openReportModal(@app.FreelancerAccountId)" title="Report this Freelancer">
                                            <i class="bi bi-flag-fill"> Report</i>
                                        </a>
                                    </div>
                                </td>
                                <td>
                                    <div class="fw-semibold">@app.JobTitle</div>
                                </td>
                                <td>@app.AppliedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    @if (app.Status == "PENDING")
                                    {
                                        <span class="badge bg-warning text-dark px-3 py-2 rounded-pill">Đang chờ</span>
                                    }
                                    else if (app.Status == "ACCEPTED")
                                    {
                                        <span class="badge bg-success px-3 py-2 rounded-pill">Đã nhận</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger px-3 py-2 rounded-pill">Từ chối</span>
                                    }
                                </td>
                                <td>
                                    <button class="btn btn-sm btn-outline-secondary" 
                                            onclick="showCoverLetter('@app.FreelancerName', '@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(app.CoverLetter))', '@(app.CvUrl ?? "")')">
                                        <i class="bi bi-eye"></i> Xem thư
                                    </button>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(app.CvUrl))
                                    {
                                        <a href="@app.CvUrl" target="_blank" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-file-earmark-arrow-down"></i> Tải CV
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Không có</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    @if (app.Status == "PENDING")
                                    {
                                        <form asp-action="Approve" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@app.Id" />
                                            <input type="hidden" name="status" value="2" />
                                            <button type="submit" class="btn btn-sm btn-success me-1">
                                                <i class="bi bi-check-lg"></i> Nhận
                                            </button>
                                        </form>
                                        <form asp-action="Approve" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@app.Id" />
                                            <input type="hidden" name="status" value="3" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                <i class="bi bi-x-lg"></i> Từ chối
                                            </button>
                                        </form>
                                    }
                                     else
                                     {
                                         <span class="text-muted small">Đã xử lý</span>
                                         @if (app.Status == "ACCEPTED")
                                         {
                                             <button type="button" class="btn btn-sm btn-primary ms-2" onclick="openReviewModal(@app.FreelancerAccountId)">
                                                 <i class="bi bi-star-fill"></i> Đánh giá
                                             </button>
                                         }
                                     }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox fs-1 d-block mb-3 opacity-50"></i>
                                Chưa có đơn ứng tuyển nào được nộp cho các dự án của bạn.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal xem Cover Letter -->
<div class="modal fade" id="coverLetterModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold" id="modalTitle">Thư giới thiệu</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="modalCvLink" class="mb-3 d-none">
                    <label class="fw-bold text-muted small mb-1">CV đính kèm:</label>
                    <div>
                        <a id="modalCvAnchor" href="#" target="_blank" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-file-earmark-arrow-down me-1"></i> Tải CV
                        </a>
                    </div>
                </div>
                <label class="fw-bold text-muted small mb-1">Thư giới thiệu:</label>
                <div id="modalBody" style="white-space: pre-line; line-height: 1.6;"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showCoverLetter(name, content, cvUrl) {
            document.getElementById('modalTitle').innerText = 'Hồ sơ ứng tuyển của ' + name;
            document.getElementById('modalBody').innerText = content;

            var cvLinkDiv = document.getElementById('modalCvLink');
            var cvAnchor = document.getElementById('modalCvAnchor');
            if (cvUrl && cvUrl.trim() !== '') {
                cvAnchor.href = cvUrl;
                cvLinkDiv.classList.remove('d-none');
            } else {
                cvLinkDiv.classList.add('d-none');
            }

            var myModal = new bootstrap.Modal(document.getElementById('coverLetterModal'));
            myModal.show();
        }
    </script>
}

<partial name="Components/_ReportFreelancerModal" />
<partial name="Components/_ReviewModal" />
