@inject IUserService CurrentUser

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />

    <title>@ViewData["Title"]</title>
    <link rel="icon" href="https://i.pinimg.com/736x/e5/39/bb/e539bbb9298e6a20ce0c61a221f21cb0.jpg">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/css/adminlte.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
    <link rel="stylesheet" href="~/css/skeleton.css" />
</head>

<body class="hold-transition sidebar-mini">

    @RenderSection("Styles", required: false)

    <div class="wrapper">

        <!-- Navbar -->
        <nav class="main-header navbar navbar-expand navbar-white navbar-light">
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" data-widget="pushmenu" href="#"><i class="fas fa-bars"></i></a>
                </li>
            </ul>

            <ul class="navbar-nav ml-auto">
                @if (CurrentUser.IsAuthenticated)
                {
                    var avatarChar = CurrentUser.Name?.Substring(0, 1).ToUpper() ?? "U";
                    <li class="nav-item">
                        <div class="d-flex align-items-center">
                            <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center"
                                 style="width:40px;height:40px;">
                                @avatarChar
                            </div>

                            <div class="ms-2">
                                <strong>@CurrentUser.Name</strong>
                                <div>
                                    <span class="badge bg-info">@CurrentUser.Role</span>
                                </div>
                            </div>
                        </div>
                    </li>
                    <li class="nav-item"> <form asp-controller="auth" asp-action="logout" method="post" class="d-inline"> <button type="submit" class="btn btn-sm nav-link text-danger"> Logout </button> </form> </li>
                }
                else
                {
                    <li class="nav-item"> <a class="nav-link" asp-controller="auth" asp-action="login">Login</a> </li>
                    <li class="nav-item"> <a class="nav-link" asp-controller="auth" asp-action="register">Register</a> </li>
                }
            </ul>
        </nav>

        <!-- Sidebar -->
        <aside class="main-sidebar sidebar-dark-primary elevation-4">

            <a href="/" class="d-flex align-items-center justify-content-center gap-2 p-2">
                <img class="img-fluid rounded-circle" width="60" height="60" src="https://i.pinimg.com/736x/e5/39/bb/e539bbb9298e6a20ce0c61a221f21cb0.jpg" />
                <div class="text-left">
                    <b>TalentBridge</b>
                    <div class="text-muted fs-tiny" style="font-size: 12px;">Freelancer Job Matching System</div>
                </div>
            </a>

            <div class="sidebar">
                <nav>
                    <ul class="nav nav-pills nav-sidebar flex-column">

                        <li class="nav-item">
                            <a href="/" class="nav-link">
                                <i class="nav-icon fas fa-home"></i>
                                <p>Home</p>
                            </a>
                        </li>
                        @if (CurrentUser.IsAdmin)
                        {
                            @await Html.PartialAsync("Menu/_Admin")
                        }

                        @if (CurrentUser.IsEmployer)
                        {
                            @await Html.PartialAsync("Menu/_Employer")
                        }

                        @if (CurrentUser.IsFreelancer)
                        {
                            @await Html.PartialAsync("Menu/_Freelancer")
                        }

                        @if (CurrentUser.IsGuest)
                        {
                            @await Html.PartialAsync("Menu/_Guest")
                        }
                    </ul>
                </nav>
            </div>
        </aside>

        <!-- Content -->
        <div class="content-wrapper p-3">

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show">
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </div>

        @await Html.PartialAsync("Components/_LoadingOverlay")

        <div class="js-modal-list">
            @RenderSection("Modals", required: false)
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/js/adminlte.min.js"></script>
    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
    <script src="~/js/ui.js"></script>
    <script src="~/js/modal.js"></script>
    <script src="~/js/app.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>