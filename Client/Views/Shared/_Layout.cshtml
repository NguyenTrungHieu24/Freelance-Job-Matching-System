@inject IUserService CurrentUser

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />

    <title>@ViewData["Title"]</title>
    <link rel="icon" href="https://i.pinimg.com/736x/e5/39/bb/e539bbb9298e6a20ce0c61a221f21cb0.jpg">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&family=Be+Vietnam+Pro:wght@300;400;500;600;700;800;900&family=DM+Sans:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/skeleton.css" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
</head>

<body class="hold-transition sidebar-mini">

    @RenderSection("Styles", required: false)

    <header class="tl-header">
        <nav class="navbar tl-navbar px-3 px-lg-4">

            <!-- Logo -->
            <a class="tl-logo navbar-brand" href="/">
                <img src="~/image/Logo.png" alt="TopLancer" class="tl-logo-img" />
            </a>

            <ul class="tl-nav-links d-none d-lg-flex list-unstyled mb-0 align-items-stretch">

                @if (CurrentUser.IsAdmin)
                {
                    @await Html.PartialAsync("Nav/_Admin")
                }

                @if (CurrentUser.IsEmployer)
                {
                    @await Html.PartialAsync("Nav/_Employer")
                }

                @if (CurrentUser.IsFreelancer)
                {
                    @await Html.PartialAsync("Nav/_Freelancer")
                }

                @if (CurrentUser.IsGuest)
                {
                    @await Html.PartialAsync("Nav/_Guest")
                }

                @if (CurrentUser.IsFinanceManager)
                {
                    @await Html.PartialAsync("Nav/_Finance")
                }

            </ul>

            <div class="tl-nav-right d-none d-lg-flex align-items-center">
                @if (CurrentUser.IsFreelancer || CurrentUser.IsEmployer)
                {
                    <div class="tl-nav-dropdown-wrap">
                        <button class="tl-wallet-btn" type="button">
                            <img src="~/image/wallet.png" alt="" class="tl-icon-img" />
                            <span id="walletBalanceNav">0 đ</span>
                        </button>
                        <div class="tl-nav-dropdown tl-nav-dropdown--right">
                            <div class="tl-wallet-balance">
                                <span class="tl-wallet-balance-label">Balance</span>
                                <span class="tl-wallet-balance-amount" id="walletBalanceDropdown">0 đ</span>
                            </div>
                        </div>
                    </div>
                }

                 @if (CurrentUser.IsAuthenticated)
                 {
                     <div class="tl-nav-dropdown-wrap ml-3" id="notificationDropdownWrap">
                         <button class="tl-icon-btn" type="button" aria-label="Notification" id="notificationBellBtn">
                             <img src="~/image/notification.png" alt="Notification" class="tl-icon-img" />
                             <span class="tl-bell-dot d-none" id="notificationDot"></span>
                         </button>
                         <div class="tl-nav-dropdown tl-nav-dropdown--right" style="width: 320px; max-height: 400px; overflow-y: auto; padding: 15px; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.1);" id="notificationList">
                             <div class="fw-bold mb-2 pb-2 border-bottom text-dark">Thông báo</div>
                             <div class="text-center py-3 text-muted" id="noNotificationText">Không có thông báo mới</div>
                             <div id="notificationItemsContainer"></div>
                         </div>
                     </div>
                 }


                @if (CurrentUser.IsAuthenticated)
                {
                    <div class="tl-nav-dropdown-wrap ml-3">
                        <button class="tl-avatar-btn" type="button">
                            <img src="~/image/user.png" alt="Avatar" class="tl-avatar-img" />
                        </button>
                        <div class="tl-nav-dropdown tl-nav-dropdown--right">
                            @if (CurrentUser.Role == "FREELANCER")
                            {
                                <a href="/freelancer/personal-info">Profile</a>
                            }
                            else if (CurrentUser.Role == "EMPLOYER")
                            {
                                <a href="/employer/personal-info">Profile</a>
                            }
                            <a href="#">Member Package</a>
                        </div>
                    </div>
                    <form asp-controller="auth" asp-action="logout" method="post" class="d-inline">
                        <button class="tl-icon-btn tl-logout-btn ml-3" type="submit" aria-label="Logout">
                            <img src="~/image/logout.png" alt="Logout" class="tl-icon-img tl-icon-red" />
                        </button>
                    </form>
                }
                else
                {
                    <a class="btn-tl rounded-3" role="button" asp-action="Login" asp-controller="Auth" aria-label="Login">
                        Login
                    </a>
                    <a class="btn-tl rounded-3" role="button" asp-action="Register" asp-controller="Auth" aria-label="Register">
                        Register
                    </a>
                }
            </div>

            <button class="tl-hamburger d-lg-none ml-auto"
                    type="button"
                    data-toggle="collapse"
                    data-target="#mobileNav"
                    aria-expanded="false">
                <span></span><span></span><span></span>
            </button>
        </nav>

        <div class="collapse tl-mobile-collapse" id="mobileNav">
            <ul class="tl-mobile-nav list-unstyled mb-0">
                <li><a class="tl-mobile-link @(ViewData["ActivePage"]?.ToString() == "Dashboard" ? "is-active" : "")" href="#">Dashboard</a></li>
                <li><a class="tl-mobile-link @(ViewData["ActivePage"]?.ToString() == "JobSearch" ? "is-active" : "")" href="#">Job Search</a></li>
                <li><a class="tl-mobile-link @(ViewData["ActivePage"]?.ToString() == "JobManagement" ? "is-active" : "")" href="#">Job Management</a></li>
                <li><a class="tl-mobile-link @(ViewData["ActivePage"]?.ToString() == "Statistical" ? "is-active" : "")" href="#">Statistical</a></li>
            </ul>
        </div>
    </header>

    <main class="tl-main">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </main>

    <footer class="tl-footer">
        <div class="container">
            <div class="tl-footer-grid">

                <div class="tl-footer-brand">
                    <a href="/" class="tl-logo mb-3 d-inline-flex align-items-center">
                        <img src="~/image/Logo.png" alt="TopLancer" class="tl-logo-img" />
                    </a>
                    <div class="tl-socials d-flex mb-3">
                        <a href="#" class="tl-social-btn">
                            <img src="~/image/Facebook.png" alt="Facebook" class="tl-icon-img" />
                        </a>
                        <a href="#" class="tl-social-btn">
                            <img src="~/image/LinkedIn.png" alt="LinkedIn" class="tl-icon-img" />
                        </a>
                        <a href="#" class="tl-social-btn">
                            <img src="~/image/Twitter.png" alt="Twitter" class="tl-icon-img" />
                        </a>
                    </div>
                    <address class="tl-contact">
                        <p>Phone: +84 (012) 3456789</p>
                        <p>Email: support@toplancer.vn</p>
                    </address>
                </div>

                <div class="tl-footer-col">
                    <h5 class="tl-footer-heading">About TopLancer</h5>
                    <ul class="tl-footer-links list-unstyled">
                        <li><a href="#">Introduce</a></li>
                        <li><a href="#">Blog</a></li>
                        <li><a href="#">Support Request</a></li>
                    </ul>
                </div>

                <div class="tl-footer-col">
                    <h5 class="tl-footer-heading">Employer</h5>
                    <ul class="tl-footer-links list-unstyled">
                        <li><a href="#">Job Posting</a></li>
                        <li><a href="#">How it works</a></li>
                        <li><a href="#">Find candidates</a></li>
                    </ul>
                </div>

                <div class="tl-footer-col">
                    <h5 class="tl-footer-heading">Candidates</h5>
                    <ul class="tl-footer-links list-unstyled">
                        <li><a href="#">Register</a></li>
                        <li><a href="#">How it works</a></li>
                        <li><a href="#">Find freelance work</a></li>
                        <li><a href="#">Find a full-time job</a></li>
                    </ul>
                </div>

            </div>
        </div>
        <div class="tl-footer-bottom">
            <div class="container">
                <p class="mb-0">Copyright &copy; 2026 topLancer Co., Ltd. All Rights Reserved.</p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/ui.js"></script>
    <script src="~/js/ajax.js"></script>
    <script src="~/js/modal.js"></script>
    <script src="~/js/app.js"></script>

    @RenderSection("Scripts", required: false)

    <script>
        document.addEventListener("DOMContentLoaded", function() {
            // Load wallet balance for Freelancer / Employer
            const isEmployerOrFreelancer = @((CurrentUser.IsFreelancer || CurrentUser.IsEmployer) ? "true" : "false");
            if (isEmployerOrFreelancer) {
                fetch("/finance/api-balance")
                    .then(r => r.json())
                    .then(data => {
                        const formatted = Number(data.balance).toLocaleString('vi-VN') + ' đ';
                        const navEl = document.getElementById('walletBalanceNav');
                        const dropEl = document.getElementById('walletBalanceDropdown');
                        if (navEl) navEl.textContent = formatted;
                        if (dropEl) dropEl.textContent = formatted;
                    })
                    .catch(() => {});
            }

            // Notifications logic
            const isAuthenticated = @(CurrentUser.IsAuthenticated ? "true" : "false");
            if (isAuthenticated) {
                const loadNotifications = () => {
                    fetch("/notifications/list")
                        .then(r => r.json())
                        .then(data => {
                            const container = document.getElementById("notificationItemsContainer");
                            const noText = document.getElementById("noNotificationText");
                            const dot = document.getElementById("notificationDot");
                            
                            if (!container) return;
                            container.innerHTML = "";
                            
                            let unreadCount = 0;
                            if (data && data.length > 0) {
                                noText.classList.add("d-none");
                                data.forEach(n => {
                                    if (!n.isRead) unreadCount++;
                                    
                                    const el = document.createElement("div");
                                    el.className = `p-2 mb-2 rounded border-bottom text-start ${n.isRead ? 'opacity-75 bg-light text-muted' : 'bg-white fw-semibold text-dark'}`;
                                    el.style.fontSize = "13px";
                                    el.style.cursor = "pointer";
                                    el.style.transition = "background-color 0.2s";
                                    el.innerHTML = `
                                        <div>${n.content}</div>
                                        <div class="text-muted" style="font-size: 11px; margin-top: 4px;">${new Date(n.createdAt).toLocaleString()}</div>
                                    `;
                                    
                                    if (!n.isRead) {
                                        el.addEventListener("click", () => {
                                            fetch(`/notifications/read/${n.id}`, { method: "POST" })
                                                .then(() => loadNotifications());
                                        });
                                        el.addEventListener("mouseover", () => el.style.backgroundColor = "#f0f4f8");
                                        el.addEventListener("mouseout", () => el.style.backgroundColor = "#fff");
                                    } else {
                                        el.addEventListener("mouseover", () => el.style.backgroundColor = "#eef2f5");
                                        el.addEventListener("mouseout", () => el.style.backgroundColor = "#f8fafc");
                                    }
                                    
                                    container.appendChild(el);
                                });
                            } else {
                                noText.classList.remove("d-none");
                            }
                            
                            if (unreadCount > 0) {
                                dot.classList.remove("d-none");
                            } else {
                                dot.classList.add("d-none");
                            }
                        })
                        .catch(() => {});
                };
                
                loadNotifications();
                // Check notifications every 30 seconds
                setInterval(loadNotifications, 30000);
            }
        });
    </script>
</body>
</html>