@model BusinessObjects.DTOs.JobDto
@inject IUserService CurrentUser

@{
    ViewData["Title"] = Model.Title;
    Layout = "_Layout";
}

<div class="container py-4">
    <!-- Back Link -->
    <div class="mb-3">
        <a href="/" class="text-decoration-none text-muted small d-inline-flex align-items-center gap-1">
            <i class="bi bi-arrow-left"></i> Trở lại danh sách công việc
        </a>
    </div>

    <div class="row g-4">
        <!-- Left Column: Job Detail (col-lg-8) -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm p-4" style="border-radius: 16px;">
                <h1 class="fw-bold text-dark mb-3" style="font-size: 1.85rem; line-height: 1.3;">@Model.Title</h1>
                
                <!-- Meta information list -->
                <div class="d-flex flex-wrap gap-2 mb-3 pb-3 border-bottom">
                    <span class="badge bg-light text-primary border px-3 py-2" style="border-radius: 20px; font-size: 0.85rem; font-weight: 500;">
                        <i class="bi bi-folder-fill me-1"></i> @Model.CategoryName
                    </span>
                    <span class="badge bg-light text-secondary border px-3 py-2" style="border-radius: 20px; font-size: 0.85rem; font-weight: 500;">
                        <i class="bi bi-calendar-event-fill me-1"></i> Đăng lúc: @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                    </span>
                    @if (Model.Deadline.HasValue)
                    {
                        <span class="badge bg-light text-danger border px-3 py-2" style="border-radius: 20px; font-size: 0.85rem; font-weight: 500;">
                            <i class="bi bi-hourglass-split me-1"></i> Hạn chót: @Model.Deadline.Value.ToString("dd/MM/yyyy")
                        </span>
                    }
                </div>

                <div class="alert alert-warning border-0 px-3 py-2 d-inline-block mb-4 fw-bold" 
                     style="border-radius: 10px; font-size: 1.05rem; color: #d97706; background-color: #fef3c7; max-width: fit-content;">
                    <i class="bi bi-cash-stack me-1"></i> Ngân sách: @Model.Budget.ToString("N0") VNĐ
                </div>

                <!-- Description -->
                <div class="mb-4">
                    <h5 class="fw-bold text-dark border-bottom pb-2 mb-3">Mô tả công việc</h5>
                    <div class="job-desc-content">
                        @Html.Raw(Model.Description)
                    </div>
                </div>

                <!-- Skills -->
                @if (Model.Skills != null && Model.Skills.Any())
                {
                    <div class="border-top pt-4">
                        <h5 class="fw-bold text-dark mb-3">Yêu cầu kỹ năng</h5>
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var skill in Model.Skills)
                            {
                                <span class="badge bg-light text-dark border px-3 py-2" style="border-radius: 8px; font-size: 0.85rem; font-weight: 500;">@skill</span>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Right Column: Employer Profile (col-lg-4) -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm p-4 text-center" style="border-radius: 16px;">
                <h5 class="fw-bold text-dark border-bottom pb-2 mb-4 text-start">Thông tin nhà tuyển dụng</h5>

                <!-- Logo -->
                <div class="d-flex justify-content-center mb-3">
                    <div class="d-flex align-items-center justify-content-center bg-light border" 
                         style="width: 80px; height: 80px; border-radius: 20px; overflow: hidden; box-shadow: 0 4px 10px rgba(0,0,0,0.05);">
                        @if (!string.IsNullOrEmpty(Model.EmployerLogo))
                        {
                            <img src="@Model.EmployerLogo" alt="Logo" style="max-width: 100%; max-height: 100%; object-fit: cover;" 
                                 onerror="this.style.display='none'; document.getElementById('logo-fallback-icon').classList.remove('d-none');" />
                            <i id="logo-fallback-icon" class="bi bi-building-fill text-muted d-none" style="font-size: 2rem;"></i>
                        }
                        else
                        {
                            <i class="bi bi-building-fill text-muted" style="font-size: 2rem;"></i>
                        }
                    </div>
                </div>

                <h4 class="fw-bold text-dark mb-1" style="font-size: 1.2rem;">@Model.EmployerName</h4>
                @if (!string.IsNullOrEmpty(Model.EmployerCompanyName))
                {
                    <div class="text-primary fw-semibold small mb-3">@Model.EmployerCompanyName</div>
                }
                else
                {
                    <div class="text-muted small mb-3" style="font-style: italic;">Cá nhân</div>
                }

                @if (!string.IsNullOrEmpty(Model.EmployerDescription))
                {
                    <p class="text-muted small px-1 mb-4" style="text-align: justify; line-height: 1.5;">@Model.EmployerDescription</p>
                }
                else
                {
                    <p class="text-muted small mb-4" style="font-style: italic;">Chưa có phần giới thiệu chi tiết.</p>
                }

                <!-- Contact Details -->
                @if (!string.IsNullOrEmpty(Model.EmployerEmail) || !string.IsNullOrEmpty(Model.EmployerPhone) || !string.IsNullOrEmpty(Model.EmployerAddress))
                {
                    <div class="bg-light border text-start p-3 mb-4" style="border-radius: 12px; font-size: 0.85rem;">
                        @if (!string.IsNullOrEmpty(Model.EmployerEmail))
                        {
                            <div class="d-flex align-items-start gap-2 mb-2">
                                <i class="bi bi-envelope-fill text-primary mt-1"></i>
                                <div>
                                    <div class="fw-bold text-dark">Email</div>
                                    <div class="text-secondary" style="word-break: break-all;">@Model.EmployerEmail</div>
                                </div>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.EmployerPhone))
                        {
                            <div class="d-flex align-items-start gap-2 mb-2">
                                <i class="bi bi-telephone-fill text-primary mt-1"></i>
                                <div>
                                    <div class="fw-bold text-dark">Điện thoại</div>
                                    <div class="text-secondary">@Model.EmployerPhone</div>
                                </div>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.EmployerAddress))
                        {
                            <div class="d-flex align-items-start gap-2">
                                <i class="bi bi-geo-alt-fill text-primary mt-1"></i>
                                <div>
                                    <div class="fw-bold text-dark">Địa chỉ</div>
                                    <div class="text-secondary">@Model.EmployerAddress</div>
                                </div>
                            </div>
                        }
                    </div>
                }

                <!-- Apply Button Action -->
                <div class="mt-2">
                    @if (!CurrentUser.IsAuthenticated)
                    {
                        <a href="/auth/login?returnUrl=@Context.Request.Path" class="btn btn-primary w-100 py-2 fw-bold" style="border-radius: 10px;">
                            <i class="bi bi-send-fill me-1"></i> Ứng tuyển ngay
                        </a>
                    }
                    else if (CurrentUser.Role == "FREELANCER")
                    {
                        <a href="/freelancer/jobs/@Model.Id" class="btn btn-primary w-100 py-2 fw-bold" style="border-radius: 10px;">
                            <i class="bi bi-send-fill me-1"></i> Ứng tuyển ngay
                        </a>
                    }
                    else
                    {
                        <button class="btn btn-secondary w-100 py-2 fw-bold" disabled style="border-radius: 10px;" title="Chỉ Freelancer mới có thể ứng tuyển">
                            <i class="bi bi-send-fill me-1"></i> Ứng tuyển
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .job-desc-content {
            font-size: 1rem;
            line-height: 1.7;
            color: #2d3748;
        }

        .job-desc-content p {
            margin-bottom: 0.8rem;
        }

        .job-attachments {
            background: #f8fafc;
            border: 1px dashed #cbd5e1;
            border-radius: 12px;
            padding: 16px;
            margin-top: 24px !important;
        }

        .job-attachments h6 {
            color: #0f172a !important;
            font-size: 0.95rem !important;
            font-weight: 700 !important;
            margin-bottom: 10px !important;
        }

        .job-attachments img {
            max-height: 130px;
            border-radius: 8px;
            border: 1px solid #e2e8f0;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.04);
            transition: all 0.25s ease;
            cursor: pointer;
        }

        .job-attachments img:hover {
            transform: scale(1.03);
            box-shadow: 0 6px 15px rgba(0, 0, 0, 0.08);
        }
    </style>
}
