@model List<BusinessObjects.DTOs.MyJobDto>
@{
    ViewData["Title"] = "My Jobs";
    Layout = "_FreelancerLayout";
}

<div class="container mt-4">
    <h2 class="mb-4">My Jobs & Applications</h2>
    
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }
    
    <ul class="nav nav-tabs" id="myJobTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="pending-tab" data-bs-toggle="tab" data-bs-target="#pending" type="button" role="tab">Pending</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="active-tab" data-bs-toggle="tab" data-bs-target="#active" type="button" role="tab">Active</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="completed-tab" data-bs-toggle="tab" data-bs-target="#completed" type="button" role="tab">Completed / Awaiting Payment</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="archived-tab" data-bs-toggle="tab" data-bs-target="#archived" type="button" role="tab">Archived / Rejected</button>
        </li>
    </ul>
    
    <div class="tab-content pt-4" id="myJobTabsContent">
        
        <div class="tab-pane fade show active" id="pending" role="tabpanel">
            @foreach(var job in Model.Where(m => m.ProgressStage == 1)) {
                @await Html.PartialAsync("_JobCardPartial", job)
            }
        </div>
        
        <div class="tab-pane fade" id="active" role="tabpanel">
            @foreach(var job in Model.Where(m => m.ProgressStage == 2)) {
                @await Html.PartialAsync("_JobCardPartial", job)
            }
        </div>
        
        <div class="tab-pane fade" id="completed" role="tabpanel">
            @foreach(var job in Model.Where(m => m.ProgressStage == 3 || m.ProgressStage == 4)) {
                @await Html.PartialAsync("_JobCardPartial", job)
            }
        </div>
        
        <div class="tab-pane fade" id="archived" role="tabpanel">
            @foreach(var job in Model.Where(m => m.ProgressStage == -1)) {
                @await Html.PartialAsync("_JobCardPartial", job)
            }
        </div>
    </div>
</div>

<div class="modal fade" id="reportModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Report Employer</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form action="/freelancer/report-employer" method="post">
          <div class="modal-body">
            <input type="hidden" id="reportEmployerId" name="ReportedUserId" />
            <div class="mb-3">
                <label>Reason</label>
                <select class="form-select" name="Reason" required>
                    <option value="Scam / Fraud">Scam / Fraud</option>
                    <option value="Non-payment">Non-payment</option>
                    <option value="Illegal job request">Illegal job request</option>
                    <option value="Other">Other</option>
                </select>
            </div>
            <div class="mb-3">
                <label>Detailed Description</label>
                <textarea class="form-control" name="Description" rows="3"></textarea>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            <button type="submit" class="btn btn-danger">Submit Report</button>
          </div>
      </form>
    </div>
  </div>
</div>

<script>
    function openReportModal(employerId) {
        document.getElementById('reportEmployerId').value = employerId;
        var myModal = new bootstrap.Modal(document.getElementById('reportModal'));
        myModal.show();
    }
</script>
