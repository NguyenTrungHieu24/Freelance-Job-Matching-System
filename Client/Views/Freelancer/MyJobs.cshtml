@model List<BusinessObjects.DTOs.MyJobDto>
@{
    ViewData["Title"] = "My Jobs";
    Layout = "_Layout";
}

<div class="container mt-4">
    <h2 class="mb-4">My Jobs & Applications</h2>
    
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }
    
    <ul class="nav nav-tabs" id="myJobTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="active-tab" data-bs-toggle="tab" data-bs-target="#active" type="button" role="tab">Active</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="completed-tab" data-bs-toggle="tab" data-bs-target="#completed" type="button" role="tab">Completed / Awaiting Payment</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="archived-tab" data-bs-toggle="tab" data-bs-target="#archived" type="button" role="tab">Archived / Rejected</button>
        </li>
    </ul>
    
    <div class="tab-content pt-4" id="myJobTabsContent">
        
        <div class="tab-pane fade show active" id="active" role="tabpanel">
            @foreach(var job in Model.Where(m => m.ProgressStage == 1)) {
                @await Html.PartialAsync("_JobCardPartial", job)
            }
        </div>
        
        <div class="tab-pane fade" id="completed" role="tabpanel">
            @foreach(var job in Model.Where(m => m.ProgressStage == 2 || m.ProgressStage == 3)) {
                @await Html.PartialAsync("_JobCardPartial", job)
            }
        </div>
        
        <div class="tab-pane fade" id="archived" role="tabpanel">
            @foreach(var job in Model.Where(m => m.ProgressStage == -1)) {
                @await Html.PartialAsync("_JobCardPartial", job)
            }
        </div>
    </div>
</div>

<partial name="_ReportEmployerModal" />

<!-- Review Modal -->
<div class="modal fade" id="reviewModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="CreateReview" asp-controller="Freelancer" method="post">
                <div class="modal-header">
                    <h5 class="modal-title">Đánh giá nhà tuyển dụng</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="RevieweeId" id="revieweeId" />
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold">Nhà tuyển dụng</label>
                        <p id="revieweeName" class="form-control-plaintext"></p>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold">Số sao (1-5)</label>
                        <select name="Rating" class="form-select" required>
                            <option value="5" selected>5 ⭐⭐⭐⭐⭐ (Rất tốt)</option>
                            <option value="4">4 ⭐⭐⭐⭐ (Tốt)</option>
                            <option value="3">3 ⭐⭐⭐ (Bình thường)</option>
                            <option value="2">2 ⭐⭐ (Kém)</option>
                            <option value="1">1 ⭐ (Rất kém)</option>
                        </select>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold">Nhận xét chi tiết</label>
                        <textarea name="Comment" class="form-control" rows="3" required placeholder="Nhập cảm nhận của bạn về nhà tuyển dụng này..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary">Gửi đánh giá</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openReviewModal(employerId, name) {
            document.getElementById('revieweeId').value = employerId;
            document.getElementById('revieweeName').textContent = name;
            var modal = new bootstrap.Modal(document.getElementById('reviewModal'));
            modal.show();
        }
    </script>
}
