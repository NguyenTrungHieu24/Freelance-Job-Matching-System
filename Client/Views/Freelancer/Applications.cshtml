@using BusinessObjects.Enums
@using BusinessObjects.DTOs
@model BusinessObjects.Common.PaginateResult<ApplicationHistoryDto>

@{
    ViewBag.Title = "Application List";
    Layout = "_Layout";
    var currentStatus = ViewData["StatusFilter"] as ApplicationStatus?;
}

<div class="container">
    <div class="fl-settings-wrapper shadow-sm">
        
        <div class="fl-settings-sidebar">
            <div class="fl-sidebar-header">Account</div>
            <ul class="fl-sidebar-nav">
                <li><a href="/freelancer/personal-info" class="fl-sidebar-link">Contact Information</a></li>
                <li><a href="/freelancer/cv-portfolio" class="fl-sidebar-link">Work Profile</a></li>
                <li><a href="/freelancer/applications" class="fl-sidebar-link active">Application List</a></li>
                <li><a href="#" class="fl-sidebar-link">Transaction History</a></li>
                <li><a href="/freelancer/change-password" class="fl-sidebar-link">Change Password</a></li>
            </ul>
        </div>
        
        <div class="fl-settings-content">
            <div class="fl-content-header d-flex justify-content-between align-items-center">
                <span>Application List</span>
                
                <div class="btn-group" role="group">
                    <a href="/freelancer/applications" class="btn btn-sm @(currentStatus == null ? "btn-primary" : "btn-outline-primary")">All</a>
                    <a href="/freelancer/applications?status=@((int)ApplicationStatus.PENDING)" class="btn btn-sm @(currentStatus == ApplicationStatus.PENDING ? "btn-primary" : "btn-outline-primary")">Pending</a>
                    <a href="/freelancer/applications?status=@((int)ApplicationStatus.ACCEPTED)" class="btn btn-sm @(currentStatus == ApplicationStatus.ACCEPTED ? "btn-primary" : "btn-outline-primary")">Accepted</a>
                    <a href="/freelancer/applications?status=@((int)ApplicationStatus.REJECTED)" class="btn btn-sm @(currentStatus == ApplicationStatus.REJECTED ? "btn-primary" : "btn-outline-primary")">Rejected</a>
                </div>
            </div>
            
            <div class="mt-4">
                @if (Model.Items != null && Model.Items.Any())
                {
                    foreach (var app in Model.Items)
                    {
                        <div class="card mb-3 border-0 shadow-sm" style="border-radius: 8px; border: 1px solid #f0f0f0 !important;">
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between align-items-start flex-wrap">
                                    <div class="d-flex gap-3 align-items-center">
                                        <img src="@(string.IsNullOrEmpty(app.Logo) ? "/image/user.png" : app.Logo)" 
                                             alt="Logo" style="width: 50px; height: 50px; border-radius: 50%; object-fit: cover; border: 1px solid #eee;" />
                                        <div>
                                            <h5 class="card-title mb-1">
                                                <a href="/freelancer/jobs/@app.JobId" class="text-decoration-none fw-bold" style="color: #0F172A;">@app.JobTitle</a>
                                            </h5>
                                            <p class="text-muted mb-0 small">
                                                <i class="bi bi-building"></i> @app.CompanyName (@app.EmployerName) • Applied on @app.AppliedAt.ToString("dd/MM/yyyy HH:mm")
                                            </p>
                                        </div>
                                    </div>
                                    <div class="text-end">
                                        @if (app.Status == ApplicationStatus.PENDING)
                                        {
                                            <span class="badge bg-warning text-dark px-3 py-2" style="font-size: 12px; border-radius: 20px;">Pending</span>
                                        }
                                        else if (app.Status == ApplicationStatus.ACCEPTED)
                                        {
                                            <span class="badge bg-success px-3 py-2" style="font-size: 12px; border-radius: 20px;">Accepted</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger px-3 py-2" style="font-size: 12px; border-radius: 20px;">Rejected</span>
                                        }
                                        <div class="mt-2 fw-bold text-primary" style="font-size: 14px;">
                                            @app.Budget.ToString("N0") VND
                                        </div>
                                    </div>
                                </div>
                                <hr class="my-3" style="border-color: #f1f5f9;">
                                <div class="d-flex justify-content-between align-items-center">
                                    <button class="btn btn-outline-secondary btn-sm" type="button" data-bs-toggle="modal" data-bs-target="#coverLetterModal-@app.Id">
                                        <i class="bi bi-file-earmark-text"></i> View Cover Letter
                                    </button>
                                    @if (app.Deadline.HasValue)
                                    {
                                        <span class="text-muted small">Job Deadline: @app.Deadline.Value.ToString("dd/MM/yyyy")</span>
                                    }
                                </div>
                            </div>
                        </div>
                        
                        <div class="modal fade" id="coverLetterModal-@app.Id" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content border-0 shadow-lg">
                                    <div class="modal-header bg-light">
                                        <h5 class="modal-title fw-bold">Cover Letter - @app.JobTitle</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                    </div>
                                    <div class="modal-body p-4" style="white-space: pre-wrap; font-size: 14px; line-height: 1.6; color: #334155;">@app.CoverLetter</div>
                                    <div class="modal-footer bg-light">
                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    
                    <div class="mt-4">
                        @await Html.PartialAsync("~/Views/Shared/Pagination/_Pagination.cshtml", Model)
                    </div>
                }
                else
                {
                    <div class="alert alert-info py-4 text-center">
                        <i class="bi bi-info-circle fs-3 d-block mb-2"></i>
                        You have not applied for any jobs yet, or there are no applications matching the selected status.
                    </div>
                }
            </div>
        </div>
    </div>
</div>