@using BusinessObjects.Enums
@model Client.Models.Freelancer.FreelancerJobDetailViewModel
@{
    ViewData["Title"] = Model.Job.Title;
}

<div class="container mt-4">
    <div class="mb-3">
        <a href="@Url.Action("JobList", "Freelancer")" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Job List
        </a>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h3 class="card-title fw-bold">@Model.Job.Title</h3>
                    <hr />
                    
                    <div class="mb-3">
                        <strong>Budget: </strong> @Model.Job.Budget.ToString("N0") VND
                    </div>
                    <hr />

                    <div class="mb-3">
                        <h5 class="fw-bold">Description</h5>
                        <p class="text-muted" style="white-space: pre-wrap;">@Model.Job.Description</p>
                    </div>
                    <hr />

                    <div class="mb-2">
                        <strong>Category: </strong> @Model.Job.CategoryName
                    </div>
                    
                    <div class="mb-2">
                        <strong>Skills: </strong>
                        @if (Model.Job.Skills != null && Model.Job.Skills.Any())
                        {
                            @string.Join(", ", Model.Job.Skills)
                        }
                        else
                        {
                            <span class="text-muted">No specific skills listed</span>
                        }
                    </div>

                    <div class="mb-2">
                        <strong>Deadline: </strong> 
                        @(Model.Job.Deadline.HasValue ? Model.Job.Deadline.Value.ToString("dd/MM/yyyy") : "No deadline")
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h4 class="card-title fw-bold mb-3">Employer</h4>
                    
                    <div class="d-flex align-items-center mb-3">
                        @if (!string.IsNullOrEmpty(Model.Job.EmployerLogo))
                        {
                            <img src="@Model.Job.EmployerLogo" alt="Avatar" class="rounded-circle me-3" style="width: 50px; height: 50px; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="bg-secondary rounded-circle d-flex align-items-center justify-content-center me-3 text-white" style="width: 50px; height: 50px;">
                                <i class="bi bi-person-fill fs-4"></i>
                            </div>
                        }
                        <div>
                            <div class="fw-bold">
                                @Model.Job.EmployerName
                                <a href="javascript:void(0)" class="text-danger ms-2 text-decoration-none" style="font-size: 0.85em;" onclick="openReportModal(@Model.Job.EmployerProfileId)" title="Report this Employer">
                                    <i class="bi bi-flag-fill"></i> Report
                                </a>
                            </div>
                            <div class="text-muted small">@Model.Job.CompanyName</div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <strong>Posted jobs: </strong> @Model.Job.PostedJobCount
                    </div>

                    <hr />

                    @if (Model.Job.IsApplied)
                    {
                        <div class="alert alert-info text-center mt-3">
                            <i class="bi bi-info-circle-fill me-2"></i>
                            You have already applied for this job. <br />
                            <strong>Status:</strong> @Model.Job.ApplyStatus.ToString()
                        </div>
                    }
                    else if (Model.Job.JobStatus == JobStatus.CLOSED || Model.Job.JobStatus == JobStatus.DELETED)
                    {
                        <div class="alert alert-info text-center mt-3">
                            <i class="bi bi-info-circle-fill me-2"></i>
                            This job has closed or deleted<br />
                        </div>
                    }
                    else
                    {
                        <form asp-action="ApplyJob" asp-controller="Freelancer" method="post">
                            <input type="hidden" asp-for="ApplicationForm.JobId" />
                            
                            <div class="mb-3">
                                <label asp-for="ApplicationForm.CoverLetter" class="form-label fw-bold">Cover letter</label>
                                <textarea asp-for="ApplicationForm.CoverLetter" class="form-control" rows="5" placeholder="Write your cover letter here..." required></textarea>
                                <span asp-validation-for="ApplicationForm.CoverLetter" class="text-danger small"></span>
                            </div>

                            <button type="submit" class="btn btn-primary w-100 fw-bold">Apply Job</button>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<partial name="Components/_ReportEmployerModal" />

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
