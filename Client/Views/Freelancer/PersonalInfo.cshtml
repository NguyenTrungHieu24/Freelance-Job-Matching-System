@model Client.Models.Freelancer.FreelancerPersonalInfoViewModel

@{
    ViewBag.Title = "Contact Information";
    Layout = "_Layout";
}

<div class="container">
    <div class="fl-settings-wrapper shadow-sm">
        
        <div class="fl-settings-sidebar">
            <div class="fl-sidebar-header">Account</div>
            <ul class="fl-sidebar-nav">
                <li><a href="/freelancer/personal-info" class="fl-sidebar-link active">Contact Information</a></li>
                <li><a href="/freelancer/cv-portfolio" class="fl-sidebar-link">Work Profile</a></li>
                <li><a href="/freelancer/applications" class="fl-sidebar-link">Application List</a></li>
                <li><a href="#" class="fl-sidebar-link">Transaction History</a></li>
                <li><a href="/freelancer/change-password" class="fl-sidebar-link">Change Password</a></li>
            </ul>
        </div>

        <div class="fl-settings-content">
            <div class="fl-content-header">Contact Information</div>
            
            <form asp-action="EditPersonalInfo" asp-controller="Freelancer" method="post" enctype="multipart/form-data">
                <div class="fl-info-grid">
                    <div class="fl-info-list">
                        
                        <div id="DisplayMode">
                            <div class="fl-info-item">
                                <strong>Account Id:</strong> @Model.PersonalInfo.AccountId
                            </div>
                            <div class="fl-info-item">
                                <strong>Full Name:</strong> @Model.PersonalInfo.FullName
                            </div>
                            <div class="fl-info-item">
                                <strong>Phone:</strong> @Model.PersonalInfo.Phone
                            </div>
                            <div class="fl-info-item">
                                <strong>Email:</strong> @Model.PersonalInfo.Email
                            </div>
                            <div class="fl-info-item">
                                <strong>Address:</strong> @Model.PersonalInfo.Address
                            </div>
                            
                            <div class="mt-4 pt-3 border-top">
                                <button type="button" class="btn-tl btn-tl-accent" onclick="toggleEditMode()">Edit Information</button>
                            </div>
                        </div>
                        
                        <div id="EditMode" class="d-none">
                            <div class="form-group mb-3">
                                <label class="font-weight-bold">Account Id</label>
                                <input type="text" class="form-control" value="@Model.PersonalInfo.AccountId" disabled />
                            </div>

                            <div class="form-group mb-3">
                                <label class="font-weight-bold">Full Name</label>
                                <input type="text" class="form-control" asp-for="PersonalInfo.FullName" />
                            </div>
                            
                            <div class="form-group mb-3">
                                <label class="font-weight-bold">Phone</label>
                                <input type="text" class="form-control" asp-for="PersonalInfo.Phone" />
                            </div>
                            
                            <div class="form-group mb-3">
                                <label class="font-weight-bold">Email</label>
                                <input type="email" class="form-control" asp-for="PersonalInfo.Email" />
                            </div>
                            
                            <div class="form-group mb-3">
                                <label class="font-weight-bold">Address</label>
                                <input type="text" class="form-control" asp-for="PersonalInfo.Address" />
                            </div>

                            <div class="mt-4 pt-3 border-top">
                                <button type="submit" class="btn-tl btn-tl-primary">Save Changes</button>
                                <button type="button" class="btn-tl btn-tl-outline-secondary ml-2" onclick="toggleEditMode()" style="padding: 8px 16px; border: 1px solid #6c757d; border-radius: 4px; background: transparent; color: #6c757d;">Cancel</button>
                            </div>
                        </div>

                    </div>

                    <!-- Cot hien thi Avatar -->
                    <div class="fl-avatar-section">
                        <strong>Avatar:</strong>
                        
                        <div class="mt-2 mb-3">
                            <img id="avatarPreview" 
                                 src="@(!string.IsNullOrEmpty(Model.PersonalInfo.ProfilePhoto) ? Model.PersonalInfo.ProfilePhoto : "/image/user.png")" 
                                 alt="Avatar" 
                                 class="fl-avatar-circle" 
                                 style="width: 120px; height: 120px; border-radius: 50%; object-fit: cover; border: 2px solid #e9ecef;" />
                        </div>
                        
                        <div class="fl-avatar-hint text-muted mb-3" style="font-size: 13px;">
                            1. Size limit: 2MB<br />
                            2. Supported formats: .jpg, .png, .jpeg
                        </div>
                        
                        <input type="file" asp-for="ProfilePhoto" id="ProfilePhotoInput" class="d-none" accept=".jpg,.jpeg,.png" onchange="previewImage(event)" />
                        
                        <button type="button" class="btn-tl btn-tl-primary" style="padding: 5px 15px; font-size: 13px;" onclick="document.getElementById('ProfilePhotoInput').click()">
                            Choose file
                        </button>
                    </div>

                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleEditMode() {
            var displayDiv = document.getElementById('DisplayMode');
            var editDiv = document.getElementById('EditMode');
            
            if (displayDiv.classList.contains('d-none')) {
                displayDiv.classList.remove('d-none');
                editDiv.classList.add('d-none');
            } else {
                displayDiv.classList.add('d-none');
                editDiv.classList.remove('d-none');
            }
        }
        
        function previewImage(event) {
            var input = event.target;
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('avatarPreview').src = e.target.result;
                }
                reader.readAsDataURL(input.files[0]);
                
                var editDiv = document.getElementById('EditMode');
                if (editDiv.classList.contains('d-none')) {
                    toggleEditMode();
                }
            }
        }
    </script>
}
