@model Client.Models.Auth.ChangePasswordViewModel

@{
    ViewBag.Title = "Change Password";
    Layout = "_FreelancerLayout";
}

<div class="container">
    <div class="fl-settings-wrapper shadow-sm">
        

        <div class="fl-settings-sidebar">
            <div class="fl-sidebar-header">Account</div>
            <ul class="fl-sidebar-nav">
                <li><a href="/freelancer/personal-info" class="fl-sidebar-link">Contact Information</a></li>
                <li><a href="/freelancer/cv-portfolio" class="fl-sidebar-link">Work Profile</a></li>
                <li><a href="#" class="fl-sidebar-link">Application List</a></li>
                <li><a href="#" class="fl-sidebar-link">Transaction History</a></li>
                <li><a href="/freelancer/change-password" class="fl-sidebar-link active">Change Password</a></li>
            </ul>
        </div>

        <div class="fl-settings-content">
            <div class="fl-content-header">Change Password</div>
            
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">@TempData["Success"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">@TempData["Error"]</div>
            }

            <form asp-action="ChangePassword" asp-controller="Freelancer" method="post">
                
                <div class="form-group mb-3">
                    <label class="font-weight-bold" asp-for="OldPassword"></label>
                    <input type="password" class="form-control" asp-for="OldPassword" placeholder="Enter current password" />
                    <span asp-validation-for="OldPassword" class="text-danger" style="font-size: 13px;"></span>
                </div>

                <div class="form-group mb-3">
                    <label class="font-weight-bold" asp-for="NewPassword"></label>
                    <input type="password" class="form-control" asp-for="NewPassword" placeholder="Enter new password" />
                    <span asp-validation-for="NewPassword" class="text-danger" style="font-size: 13px;"></span>
                </div>

                <div class="form-group mb-3">
                    <label class="font-weight-bold" asp-for="ConfirmPassword"></label>
                    <input type="password" class="form-control" asp-for="ConfirmPassword" placeholder="Confirm new password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger" style="font-size: 13px;"></span>
                </div>

                <div class="mt-4 pt-3 border-top">
                    <button type="submit" class="btn-tl btn-tl-primary">Update Password</button>
                </div>
            </form>
        </div>
    </div>
</div>