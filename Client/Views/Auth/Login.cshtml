<style>
    :root {
        --primary: #143f63;
        --primary-dark: #0f3350;
        --primary-light: #1d4f7c;
        --bg: #f4f8fc;
        --surface: #ffffff;
        --surface-soft: #eef4f9;
        --text: #1e293b;
        --muted: #64748b;
        --border: #d7e2ed;
    }

    body {
        background: var(--bg);
        color: var(--text);
        font-family: 'Inter', sans-serif;
    }

    .login-wrapper {
        min-height: 100vh;
    }

    .login-card {
        border: none;
        border-radius: 28px;
        overflow: hidden;
        box-shadow: 0 20px 50px rgba(20, 63, 99, 0.14);
    }

    .left-panel {
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
        color: white;
        padding: 60px 45px;
        position: relative;
    }

        .left-panel::before {
            content: "";
            position: absolute;
            width: 300px;
            height: 300px;
            background: rgba(255,255,255,0.08);
            border-radius: 50%;
            top: -80px;
            right: -80px;
        }

    .brand-logo {
        width: 75px;
        height: 75px;
        object-fit: cover;
        border-radius: 50%;
        border: 4px solid rgba(255,255,255,0.2);
        background: #fff;
    }

    .right-panel {
        background: white;
        padding: 55px 45px;
    }

    .form-control {
        height: 52px;
        border-radius: 14px;
        border: 1px solid var(--border);
        padding-left: 16px;
    }

        .form-control:focus {
            box-shadow: none;
            border-color: var(--primary);
        }

    .role-card {
        border: 2px solid #e9eef5;
        border-radius: 16px;
        padding: 18px;
        cursor: pointer;
        transition: .25s;
        background: #fff;
    }

        .role-card:hover {
