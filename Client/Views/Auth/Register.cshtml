@model RegisterViewModel
@{
    ViewData["Title"] = "Login";
    Layout = "_LayoutAuth";
}


<div class="register-box">

    <div class="register-logo">
        <a href="/" class="d-flex align-items-center justify-content-center gap-2">
            <img class="img-fluid rounded-circle" width="80" height="80" src="https://i.pinimg.com/736x/e5/39/bb/e539bbb9298e6a20ce0c61a221f21cb0.jpg" />
            <div class="text-left">
                <b>TalentBridge</b>
                <div class="text-muted fs-6">Freelancer Job Matching System</div>
            </div>
        </a>
    </div>

    <div class="card">

        <div class="card-body register-card-body">

            <p class="login-box-msg">Create new account</p>

            <form asp-action="Register" method="post">

                <div class="input-group mb-3">
                    <input asp-for="Name" class="form-control" placeholder="Name" maxlength="255">
                    <div class="input-group-append">
                        <div class="input-group-text">
                            <i class="fas fa-user"></i>
                        </div>
                    </div>
                </div>

                <div class="input-group mb-3">
                    <input asp-for="Email" type="email" class="form-control" placeholder="Email">
                    <div class="input-group-append">
                        <div class="input-group-text">
                            <i class="fas fa-envelope"></i>
                        </div>
                    </div>
                </div>

                <div class="input-group mb-3">
                    <input asp-for="Password" type="password" class="form-control" placeholder="Password">
                    <div class="input-group-append">
                        <div class="input-group-text">
                            <i class="fas fa-lock"></i>
                        </div>
                    </div>
                </div>

                <div class="input-group mb-3">
                    <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Confirm Password">
                    <div class="input-group-append">
                        <div class="input-group-text">
                            <i class="fas fa-lock"></i>
                        </div>
                    </div>
                </div>

                <div asp-validation-summary="All" class="text-danger"></div>

                @if (ViewBag.Error != null)
                {
                    <div class="text-danger mb-2">
                        @ViewBag.Error
                    </div>
                }

                <button type="submit" class="btn btn-primary btn-block">
                    Register
                </button>

            </form>

            <!-- CTA BACK TO LOGIN -->
            <div class="mt-3 text-center">
                <a asp-action="Login" class="text-primary">
                    ← Already have an account? Login
                </a>
            </div>

        </div>

    </div>

</div>
