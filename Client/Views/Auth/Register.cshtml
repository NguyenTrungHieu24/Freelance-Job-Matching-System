@model RegisterViewModel

@{
    ViewData["Title"] = "Register";
    Layout = "_LayoutAuth";
}

<style>
    :root {
        --primary: #143f63;
        --primary-dark: #0f3350;
        --primary-light: #1d4f7c;
        --bg: #f4f8fc;
        --surface: #ffffff;
        --surface-soft: #eef4f9;
        --text: #1e293b;
        --muted: #64748b;
        --border: #d7e2ed;
    }

    body {
        background: var(--bg);
    }

    .auth-page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
    }

    .auth-card {
        width: 100%;
        max-width: 1100px;
        border: none;
        border-radius: 28px;
        overflow: hidden;
        box-shadow: 0 20px 50px rgba(20, 63, 99, 0.14);
    }

    .auth-left {
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
        color: #fff;
        padding: 60px 45px;
        position: relative;
    }

        .auth-left::before {
            content: "";
            position: absolute;
            width: 280px;
            height: 280px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.08);
            top: -80px;
            right: -80px;
        }

    .brand-logo {
        width: 80px;
        height: 80px;
        object-fit: cover;
        border-radius: 50%;
        border: 4px solid rgba(255, 255, 255, 0.2);
        background: #fff;
    }

    .auth-right {
        background: #fff;
        padding: 50px 45px;
    }

    .form-control {
        height: 52px;
        border-radius: 14px 0 0 14px;
        border: 1px solid var(--border);
        border-right: none;
        padding-left: 16px;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .input-group-text {
        height: 52px;
        border-radius: 0 14px 14px 0;
        border: 1px solid var(--border);
        border-left: none;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .input-group:focus-within .form-control {
        border-color: var(--primary);
        box-shadow: 0 0 0 4px rgba(20, 63, 99, 0.12);
        background-color: #fff;
    }

    .input-group:focus-within .input-group-text {
        border-color: var(--primary);
        box-shadow: 0 0 0 4px rgba(20, 63, 99, 0.12);
        background-color: #fff;
    }

    .submit-btn {
        height: 52px;
        border-radius: 14px;
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
        border: none;
        font-weight: 600;
        transition: all 0.25s ease;
    }

        .submit-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 24px rgba(20, 63, 99, .22);
            opacity: 0.95;
        }

    .small-link {
        color: var(--primary);
        text-decoration: none;
        font-weight: 600;
    }

        .small-link:hover {
            text-decoration: underline;
        }

    .role-card {
        border: 2px solid #e9eef5;
        border-radius: 16px;
        padding: 18px;
        cursor: pointer;
        transition: .25s;
        background: #fff;
    }

        .role-card:hover {
            border-color: var(--primary);
            transform: translateY(-2px);
            box-shadow: 0 8px 16px rgba(20, 63, 99, .06);
        }

    .btn-check:checked + .role-card {
        border-color: var(--primary);
        background: #eef5ff;
    }
</style>

<div class="auth-page">
    <div class="card auth-card">
        <div class="row g-0">

            <!-- LEFT -->
            <div class="col-lg-5 d-none d-lg-flex flex-column justify-content-between auth-left">
                <div>
                    <div class="d-flex align-items-center gap-3 mb-5">
                        <img class="brand-logo"
                             src="~/image/Logo.png"
                             alt="TopLancer" />

                        <div>
                            <h3 class="fw-bold mb-1">TopLancer</h3>
                            <div class="small opacity-75">Hệ thống kết nối Freelancer</div>
                        </div>
                    </div>

                    <h1 class="fw-bold mb-4" style="font-size: 42px; line-height: 1.1;">
                        Tham gia<br />
                        TopLancer
                    </h1>

                    <p class="opacity-90" style="line-height: 1.7; max-width: 360px;">
                        Tạo tài khoản để bắt đầu kết nối với Freelancer hoặc Employer,
                        quản lý dự án và mở rộng cơ hội làm việc.
                    </p>
                </div>

                <div class="mt-5">
                    <div class="d-flex gap-4 flex-wrap">
                        <div>
                            <h3 class="fw-bold mb-1">Nhanh</h3>
                            <small>Đăng ký tức thì</small>
                        </div>
                        <div>
                            <h3 class="fw-bold mb-1">An toàn</h3>
                            <small>Bảo mật tuyệt đối</small>
                        </div>
                        <div>
                            <h3 class="fw-bold mb-1">Dễ dàng</h3>
                            <small>Thao tác đơn giản</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- RIGHT -->
            <div class="col-lg-7 auth-right">

                <div class="mb-4">
                    <h2 class="fw-bold mb-2">Tạo tài khoản ✨</h2>
                    <p class="text-muted mb-0">Đăng ký để tiếp tục sử dụng hệ thống</p>
                </div>

                <form asp-action="Register" method="post">
                    @Html.AntiForgeryToken()

                    <!-- ROLE -->
                    <div class="mb-4">
                        <label class="fw-semibold mb-3 d-block">Chọn vai trò của bạn</label>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <input type="radio"
                                       class="btn-check"
                                       name="Role"
                                       id="roleFreelancer"
                                       value="3"
                                       checked>


                                <label class="role-card w-100" for="roleFreelancer">
                                    <div class="d-flex align-items-center gap-3">
                                        <img src="~/image/anhfrelancer.png"
                                             alt="Freelancer"
                                             width="50"
                                             height="50"
                                             >
                                        <div>
                                            <h6 class="mb-1 fw-bold">Freelancer</h6>
                                            <small class="text-muted">Tìm kiếm việc làm & dự án</small>
                                        </div>
                                    </div>
                                </label>


                            </div>

                            <div class="col-md-6">
                                <input type="radio"
                                       class="btn-check"
                                       name="Role"
                                       id="roleEmployer"
                                       value="2">

                                <label class="role-card w-100" for="roleEmployer">
                                    <div class="d-flex align-items-center gap-3">

                                        <img src="~/image/employer.png"
                                             alt="Employer"
                                             width="50"
                                             height="50">

                                        <div>
                                            <h6 class="mb-1 fw-bold">Employer</h6>
                                            <small class="text-muted">Đăng tin & tuyển dụng</small>
                                        </div>

                                    </div>
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Name" class="fw-semibold mb-2">Họ và tên</label>
                            <div class="input-group mb-1">
                                <input asp-for="Name" class="form-control" placeholder="Họ và tên" maxlength="255">
                                <span class="input-group-text bg-white">
                                    <i class="fas fa-user text-muted"></i>
                                </span>
                            </div>
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Email" class="fw-semibold mb-2">Email</label>
                            <div class="input-group mb-1">
                                <input asp-for="Email" type="email" class="form-control" placeholder="Email">
                                <span class="input-group-text bg-white">
                                    <i class="fas fa-envelope text-muted"></i>
                                </span>
                            </div>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Password" class="fw-semibold mb-2">Mật khẩu</label>
                            <div class="input-group mb-1">
                                <input asp-for="Password" type="password" class="form-control" placeholder="Mật khẩu">
                                <span class="input-group-text bg-white">
                                    <i class="fas fa-lock text-muted"></i>
                                </span>
                            </div>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ConfirmPassword" class="fw-semibold mb-2">Xác nhận mật khẩu</label>
                            <div class="input-group mb-1">
                                <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Xác nhận mật khẩu">
                                <span class="input-group-text bg-white">
                                    <i class="fas fa-lock text-muted"></i>
                                </span>
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>
                    </div>

                    <div asp-validation-summary="All" class="text-danger mt-3"></div>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger mt-3 mb-0">
                            @ViewBag.Error
                        </div>
                    }

                    <button type="submit" class="btn btn-primary submit-btn w-100 mt-4">
                        Đăng ký
                    </button>

                    <div class="mt-4 text-center">
                        <span class="text-muted">Bạn đã có tài khoản? </span>
                        <a asp-action="Login" class="small-link">Đăng nhập tại đây</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>