@model Client.Models.Auth.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Quên mật khẩu";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h3 class="card-title text-center mb-3">Tìm lại mật khẩu</h3>
                    <p class="text-muted text-center small">Nhập email tài khoản của bạn để nhận liên kết đặt lại mật khẩu.</p>

                    @if (ViewBag.SuccessMessage != null)
                    {
                        <div class="alert alert-success">@ViewBag.SuccessMessage</div>
                    }
                    else
                    {
                        <form asp-action="ForgotPassword" method="post">
                            <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

                            <div class="mb-3">
                                <label asp-for="Email" class="form-label">Địa chỉ Email</label>
                                <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <button type="submit" class="btn btn-primary w-100">Gửi yêu cầu</button>
                        </form>
                    }

                    <div class="text-center mt-3">
                        <a asp-action="Login" class="text-decoration-none small">Quay lại đăng nhập</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>