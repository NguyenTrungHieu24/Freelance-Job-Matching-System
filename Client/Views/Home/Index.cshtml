@inject IUserService CurrentUser

@{
    ViewData["Title"] = "Home";
    Layout = "_Layout";
}
@section Styles {
    <link rel="stylesheet" href="~/css/home.css" />
}

<section class="content">
<div class="container-fluid p-0">
    <!-- ========== TOPBAR ========== -->
    <nav class="fv-topbar">
        <div class="fv-wrap fv-topbar-inner">
            <a href="/" class="fv-brand">Talent<span>Bridge</span></a>

            <div class="fv-nav">
                <a href="#categories">Danh mục</a>
                <a href="#projects">Dự án</a>
                <a href="#freelancers">Freelancers</a>
                <a href="#how">Cách thức</a>
            </div>

            <div class="fv-nav-actions">
                @if (CurrentUser.IsAuthenticated)
                {
                    <span style="color:rgba(255,255,255,.8);font-size:.9rem;font-weight:600">
                        Xin chào, <strong style="color:#fff">@CurrentUser.Name</strong>
                    </span>
                }
                else
                {
                    <a href="/auth/login" class="btn-login">Đăng nhập</a>
                    <a href="/auth/register" class="btn-register">Đăng ký</a>
                }
            </div>
        </div>
    </nav>

    <!-- ========== HERO ========== -->
    <section class="fv-hero">
        <div class="fv-wrap fv-hero-inner">
            <div class="fv-hero-badge">
                <i class="bi bi-lightning-charge-fill"></i>
                Vietnam's #1 Freelance Platform
            </div>

            <h1>
                Find The Right Projects —<br>
                Connect Fast, Pay Securely
            </h1>

            <p class="fv-hero-sub">
                Thousands of new projects every day. Connect employers and freelancers
                professionally in just a few minutes.
            </p>

            <!-- Search bar -->
            <div class="fv-search-wrap">
                <select class="fv-search-select">
                    <option>All Categories</option> 
                    <option>Programming</option>
                    <option>Design</option>
                    <option>Marketing</option>
                    <option>Content Writing</option>
                </select>

                <input class="fv-search-input" type="text"
                       placeholder="e.g. Logo Design, React Website, SEO Content..." />

                <button class="fv-search-btn">
                    <i class="bi bi-search"></i> Search
                </button>
            </div>

            <!-- Popular tags -->
            <div class="fv-tags">
                <span style="color:rgba(255,255,255,.5);font-size:.82rem;font-weight:600">Phổ biến:</span>
                <a href="#" class="fv-tag">React</a>
                <a href="#" class="fv-tag">Figma UI/UX</a>
                <a href="#" class="fv-tag">SEO</a>
                <a href="#" class="fv-tag">ASP.NET</a>
                <a href="#" class="fv-tag">Viết bài</a>
                <a href="#" class="fv-tag">Logo Design</a>
                <a href="#" class="fv-tag">Mobile App</a>
            </div>
        </div>
    </section>

    <!-- ========== STATS BAR ========== -->
    <div class="fv-stats">
        <div class="fv-wrap">
            <div class="fv-stats-inner">
                <div class="fv-stat">
                    <div class="fv-stat-num">18,400+</div>
                    <div class="fv-stat-label">Freelancer đã đăng ký</div>
                </div>
                <div class="fv-stat">
                    <div class="fv-stat-num">9,200+</div>
                    <div class="fv-stat-label">Dự án hoàn thành</div>
                </div>
                <div class="fv-stat">
                    <div class="fv-stat-num">3,500+</div>
                    <div class="fv-stat-label">Nhà tuyển dụng</div>
                </div>
                <div class="fv-stat">
                    <div class="fv-stat-num">98%</div>
                    <div class="fv-stat-label">Tỷ lệ hài lòng</div>
                </div>
            </div>
        </div>
    </div>

    <!-- ========== CATEGORIES ========== -->
    <section class="fv-cats" id="categories">
        <div class="fv-wrap">
            <div class="fv-section-head d-flex justify-content-between align-items-end flex-wrap gap-3">
                <div>
                    <h2>Khám Phá Theo Danh Mục</h2>
                    <p>Tìm freelancer hoặc dự án theo lĩnh vực chuyên môn</p>
                </div>
                <a href="#" class="fv-see-all">Xem tất cả <i class="bi bi-arrow-right"></i></a>
            </div>

            <div class="fv-cat-grid">
                <a href="#" class="fv-cat-card">
                    <div class="fv-cat-icon"><i class="bi bi-code-slash"></i></div>
                    <div class="fv-cat-name">Lập trình Web</div>
                    <div class="fv-cat-count">1,240 dự án</div>
                </a>
                <a href="#" class="fv-cat-card">
                    <div class="fv-cat-icon"><i class="bi bi-phone"></i></div>
                    <div class="fv-cat-name">Mobile App</div>
                    <div class="fv-cat-count">580 dự án</div>
                </a>
                <a href="#" class="fv-cat-card">
                    <div class="fv-cat-icon"><i class="bi bi-palette2"></i></div>
                    <div class="fv-cat-name">UI/UX Design</div>
                    <div class="fv-cat-count">960 dự án</div>
                </a>
                <a href="#" class="fv-cat-card">
                    <div class="fv-cat-icon"><i class="bi bi-vector-pen"></i></div>
                    <div class="fv-cat-name">Thiết kế đồ họa</div>
                    <div class="fv-cat-count">720 dự án</div>
                </a>
                <a href="#" class="fv-cat-card">
                    <div class="fv-cat-icon"><i class="bi bi-megaphone"></i></div>
                    <div class="fv-cat-name">Marketing</div>
                    <div class="fv-cat-count">440 dự án</div>
                </a>
                <a href="#" class="fv-cat-card">
                    <div class="fv-cat-icon"><i class="bi bi-pencil-square"></i></div>
                    <div class="fv-cat-name">Viết nội dung</div>
                    <div class="fv-cat-count">810 dự án</div>
                </a>
                <a href="#" class="fv-cat-card">
                    <div class="fv-cat-icon"><i class="bi bi-camera-video"></i></div>
                    <div class="fv-cat-name">Video & Motion</div>
                    <div class="fv-cat-count">310 dự án</div>
                </a>
                <a href="#" class="fv-cat-card">
                    <div class="fv-cat-icon"><i class="bi bi-bar-chart-line"></i></div>
                    <div class="fv-cat-name">Phân tích dữ liệu</div>
                    <div class="fv-cat-count">270 dự án</div>
                </a>
            </div>
        </div>
    </section>

    <!-- ========== PROJECTS ========== -->
    <section class="fv-jobs" id="projects">
        <div class="fv-wrap">
            <div class="fv-section-head d-flex justify-content-between align-items-end flex-wrap gap-3 mb-4">
                <div>
                    <h2>Dự Án Mới Nhất</h2>
                    <p>Cập nhật liên tục — hàng trăm dự án mới mỗi ngày</p>
                </div>
                <a href="#" class="fv-see-all">Xem tất cả <i class="bi bi-arrow-right"></i></a>
            </div>

            <div class="fv-job-grid">

                <!-- Card 1 -->
                <a href="#" class="fv-job-card">
                    <div class="fv-job-header">
                        <div class="fv-job-logo"><i class="bi bi-globe"></i></div>
                        <div>
                            <div class="fv-job-title">Thiết kế & lập trình website bán hàng Shopify</div>
                            <div class="fv-job-company">Công ty Thời Trang VOGUE VN</div>
                        </div>
                    </div>
                    <p class="fv-job-desc">Cần freelancer có kinh nghiệm Shopify, tích hợp thanh toán VNPAY, thiết kế responsive hiện đại cho ngành thời trang.</p>
                    <div class="fv-job-footer">
                        <div class="fv-job-tags">
                            <span class="fv-job-tag">Shopify</span>
                            <span class="fv-job-tag">Liquid</span>
                            <span class="fv-job-tag">UI/UX</span>
                        </div>
                        <span class="fv-job-budget">5–10 triệu</span>
                    </div>
                    <div class="fv-job-meta">
                        <span><i class="bi bi-clock me-1"></i>2 giờ trước</span>
                        <span class="fv-bid-badge"><i class="bi bi-people me-1"></i>8 bids</span>
                    </div>
                </a>

                <!-- Card 2 -->
                <a href="#" class="fv-job-card">
                    <div class="fv-job-header">
                        <div class="fv-job-logo"><i class="bi bi-phone"></i></div>
                        <div>
                            <div class="fv-job-title">Xây dựng app quản lý đặt lịch React Native</div>
                            <div class="fv-job-company">BeautyBook Startup</div>
                        </div>
                    </div>
                    <p class="fv-job-desc">App đặt lịch spa/salon, tích hợp calendar, push notification, thanh toán online. Backend Node.js đã có sẵn.</p>
                    <div class="fv-job-footer">
                        <div class="fv-job-tags">
                            <span class="fv-job-tag">React Native</span>
                            <span class="fv-job-tag">Firebase</span>
                            <span class="fv-job-tag">REST API</span>
                        </div>
                        <span class="fv-job-budget">12–18 triệu</span>
                    </div>
                    <div class="fv-job-meta">
                        <span><i class="bi bi-clock me-1"></i>5 giờ trước</span>
                        <span class="fv-bid-badge"><i class="bi bi-people me-1"></i>14 bids</span>
                    </div>
                </a>

                <!-- Card 3 -->
                <a href="#" class="fv-job-card">
                    <div class="fv-job-header">
                        <div class="fv-job-logo"><i class="bi bi-palette2"></i></div>
                        <div>
                            <div class="fv-job-title">Thiết kế bộ nhận diện thương hiệu startup F&B</div>
                            <div class="fv-job-company">The Coffee Collective</div>
                        </div>
                    </div>
                    <p class="fv-job-desc">Cần logo, brand guideline, menu design, bao bì sản phẩm cho chuỗi cà phê mới. Phong cách minimalist, màu đất.</p>
                    <div class="fv-job-footer">
                        <div class="fv-job-tags">
                            <span class="fv-job-tag">Branding</span>
                            <span class="fv-job-tag">Illustrator</span>
                            <span class="fv-job-tag">Packaging</span>
                        </div>
                        <span class="fv-job-budget">8–15 triệu</span>
                    </div>
                    <div class="fv-job-meta">
                        <span><i class="bi bi-clock me-1"></i>1 ngày trước</span>
                        <span class="fv-bid-badge"><i class="bi bi-people me-1"></i>22 bids</span>
                    </div>
                </a>

                <!-- Card 4 -->
                <a href="#" class="fv-job-card">
                    <div class="fv-job-header">
                        <div class="fv-job-logo"><i class="bi bi-pencil-square"></i></div>
                        <div>
                            <div class="fv-job-title">Viết 20 bài blog chuẩn SEO về tài chính cá nhân</div>
                            <div class="fv-job-company">FinSmart Media</div>
                        </div>
                    </div>
                    <p class="fv-job-desc">Cần writer am hiểu tài chính, đầu tư. Mỗi bài 1200–1500 từ, keyword research có sẵn, deadline 30 ngày.</p>
                    <div class="fv-job-footer">
                        <div class="fv-job-tags">
                            <span class="fv-job-tag">SEO Writing</span>
                            <span class="fv-job-tag">Tài chính</span>
                        </div>
                        <span class="fv-job-budget">3–6 triệu</span>
                    </div>
                    <div class="fv-job-meta">
                        <span><i class="bi bi-clock me-1"></i>1 ngày trước</span>
                        <span class="fv-bid-badge"><i class="bi bi-people me-1"></i>7 bids</span>
                    </div>
                </a>

                <!-- Card 5 -->
                <a href="#" class="fv-job-card">
                    <div class="fv-job-header">
                        <div class="fv-job-logo"><i class="bi bi-bar-chart-line"></i></div>
                        <div>
                            <div class="fv-job-title">Phân tích dữ liệu bán hàng & dashboard Power BI</div>
                            <div class="fv-job-company">RetailMax Corp</div>
                        </div>
                    </div>
                    <p class="fv-job-desc">Xây dựng dashboard Power BI từ dữ liệu SQL Server, báo cáo doanh thu theo vùng, sản phẩm và kênh phân phối.</p>
                    <div class="fv-job-footer">
                        <div class="fv-job-tags">
                            <span class="fv-job-tag">Power BI</span>
                            <span class="fv-job-tag">SQL</span>
                            <span class="fv-job-tag">DAX</span>
                        </div>
                        <span class="fv-job-budget">4–8 triệu</span>
                    </div>
                    <div class="fv-job-meta">
                        <span><i class="bi bi-clock me-1"></i>2 ngày trước</span>
                        <span class="fv-bid-badge"><i class="bi bi-people me-1"></i>11 bids</span>
                    </div>
                </a>

                <!-- Card 6 -->
                <a href="#" class="fv-job-card">
                    <div class="fv-job-header">
                        <div class="fv-job-logo"><i class="bi bi-camera-video"></i></div>
                        <div>
                            <div class="fv-job-title">Dựng video quảng cáo TikTok & Reels 15s</div>
                            <div class="fv-job-company">GreenLife Products</div>
                        </div>
                    </div>
                    <p class="fv-job-desc">Cần 5 video quảng cáo sản phẩm FMCG, phong cách trendy, có hook mạnh trong 3 giây đầu. Có sẵn footage thô.</p>
                    <div class="fv-job-footer">
                        <div class="fv-job-tags">
                            <span class="fv-job-tag">Video Edit</span>
                            <span class="fv-job-tag">After Effects</span>
                            <span class="fv-job-tag">TikTok</span>
                        </div>
                        <span class="fv-job-budget">2–4 triệu</span>
                    </div>
                    <div class="fv-job-meta">
                        <span><i class="bi bi-clock me-1"></i>3 ngày trước</span>
                        <span class="fv-bid-badge"><i class="bi bi-people me-1"></i>18 bids</span>
                    </div>
                </a>

            </div>
        </div>
    </section>

    <!-- ========== HOW IT WORKS ========== -->
    <section class="fv-how" id="how">
        <div class="fv-wrap">
            <div class="fv-section-head text-center" style="max-width:600px;margin:0 auto">
                <h2>Cách Thức Hoạt Động</h2>
                <p>Chỉ 4 bước đơn giản để bắt đầu dự án của bạn</p>
            </div>

            <div class="fv-how-grid">
                <div class="fv-step">
                    <div class="fv-step-num">1</div>
                    <h3>Đăng ký tài khoản</h3>
                    <p>Tạo hồ sơ miễn phí trong 2 phút. Xác minh danh tính để tăng độ tin cậy với khách hàng.</p>
                </div>
                <div class="fv-step">
                    <div class="fv-step-num">2</div>
                    <h3>Tìm & Đặt giá thầu</h3>
                    <p>Browse hàng nghìn dự án phù hợp kỹ năng. Đặt giá thầu cạnh tranh với proposal hấp dẫn.</p>
                </div>
                <div class="fv-step">
                    <div class="fv-step-num">3</div>
                    <h3>Thực hiện dự án</h3>
                    <p>Chat trực tiếp với employer, quản lý milestone, cập nhật tiến độ qua hệ thống.</p>
                </div>
                <div class="fv-step">
                    <div class="fv-step-num">4</div>
                    <h3>Nhận thanh toán</h3>
                    <p>Tiền được giữ cọc an toàn. Giải ngân ngay sau khi employer xác nhận hoàn thành.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ========== TOP FREELANCERS ========== -->
    <section class="fv-freelancers" id="freelancers">
        <div class="fv-wrap">
            <div class="fv-section-head d-flex justify-content-between align-items-end flex-wrap gap-3 mb-4">
                <div>
                    <h2>Freelancer Nổi Bật</h2>
                    <p>Những chuyên gia được đánh giá cao nhất trên nền tảng</p>
                </div>
                <a href="#" class="fv-see-all">Xem tất cả <i class="bi bi-arrow-right"></i></a>
            </div>

            <div class="fv-fl-grid">
                <a href="#" class="fv-fl-card">
                    <div class="fv-fl-avatar" style="background:#e8f4fd;color:#1a6fb3;font-size:1.6rem">👨‍💻</div>
                    <div class="fv-fl-name">Nguyen Trung Hieu</div>
                    <div class="fv-fl-title">Full-stack Developer</div>
                    <div class="fv-fl-stars">★★★★★ <span style="color:var(--muted)">(48)</span></div>
                    <div class="fv-fl-rate">từ 800k/ngày</div>
                    <span class="fv-fl-tag">React · Node.js</span>
                </a>
                <a href="#" class="fv-fl-card">
                    <div class="fv-fl-avatar" style="background:#fef3e8;color:#c2660a;font-size:1.6rem">👩‍🎨</div>
                    <div class="fv-fl-name">Trần Tuan Kiet</div>
                    <div class="fv-fl-title">UI/UX Designer</div>
                    <div class="fv-fl-stars">★★★★★ <span style="color:var(--muted)">(73)</span></div>
                    <div class="fv-fl-rate">từ 600k/ngày</div>
                    <span class="fv-fl-tag">Figma · Framer</span>
                </a>
                <a href="#" class="fv-fl-card">
                    <div class="fv-fl-avatar" style="background:#edfaf4;color:#14803a;font-size:1.6rem">📊</div>
                    <div class="fv-fl-name">Lê Tuan Duong</div>
                    <div class="fv-fl-title">Data Analyst</div>
                    <div class="fv-fl-stars">★★★★☆ <span style="color:var(--muted)">(31)</span></div>
                    <div class="fv-fl-rate">từ 700k/ngày</div>
                    <span class="fv-fl-tag">Python · Power BI</span>
                </a>
                <a href="#" class="fv-fl-card">
                    <div class="fv-fl-avatar" style="background:#fce8f6;color:#a020a0;font-size:1.6rem">✍️</div>
                    <div class="fv-fl-name">Tran Trong Hien</div>
                    <div class="fv-fl-title">Content Strategist</div>
                    <div class="fv-fl-stars">★★★★★ <span style="color:var(--muted)">(59)</span></div>
                    <div class="fv-fl-rate">từ 400k/ngày</div>
                    <span class="fv-fl-tag">SEO · Copywriting</span>
                </a>
                <a href="#" class="fv-fl-card">
                    <div class="fv-fl-avatar" style="background:#fff3e8;color:#e05c00;font-size:1.6rem">📱</div>
                    <div class="fv-fl-name">Tran Duc Hoang</div>
                    <div class="fv-fl-title">Mobile Developer</div>
                    <div class="fv-fl-stars">★★★★★ <span style="color:var(--muted)">(40)</span></div>
                    <div class="fv-fl-rate">từ 900k/ngày</div>
                    <span class="fv-fl-tag">Flutter · Swift</span>
                </a>
            </div>
        </div>
    </section>

    <!-- ========== CTA BANNER ========== -->
    <section class="fv-cta">
        <div class="fv-wrap fv-cta-inner">
            @if (!CurrentUser.IsAuthenticated)
            {
                <h2>Ready To Start Your Freelance Journey?</h2>
                <p>Sign up for free and find your first project today.</p>

                <div class="fv-cta-actions">
                    <a href="/auth/register" class="btn-cta-white">
                        Create Free Account
                    </a>

                    <a href="/auth/login" class="btn-cta-outline">
                        Login
                    </a>
                </div>
            }
            else
            {
                <h2>
                    Welcome Back,
                    <strong>@CurrentUser.Name</strong>! 👋
                </h2>

                <p>
                    Hundreds of new projects are waiting for you —
                    start exploring now.
                </p>

                <div class="fv-cta-actions">
                    <a href="#projects" class="btn-cta-white">
                        View Latest Projects
                    </a>
                </div>
            }
        </div>
    </section>
</div>
</section>

        <!-- Floating Chat Button -->
        <button class="fab-chat">
            <i class="bi bi-chat-dots fs-5"></i>
            <span class="chat-tooltip">Chat with us!</span>
        </button>

@section Scripts{
    <script src="~/js/home.js" asp-append-version="true"></script>
}

       
