@inject IUserService CurrentUser

@{
    ViewData["Title"] = "Home";
    Layout = "_Layout";
}


<section class="content">
    <div class="container-fluid">

        <div class="card">
            <div class="card-body text-center">

                <div class="p-5 mb-4 rounded-4 text-white text-center"
                     style="background: linear-gradient(135deg, #0d6efd, #6610f2);">

                    <h1 class="fw-bold display-5">
                        👋 Xin chào
                        @if (CurrentUser.IsAuthenticated)
                        {
                            <strong>@(CurrentUser.Name)</strong>
                        }
                        else
                        {

                        }
                    </h1>

                    <p class="mt-3 fs-5">
                        Are you ready to conquer new jobs?
                    </p>
                </div>

                @if (!CurrentUser.IsAuthenticated)
                {
                    <a href="/auth/login" class="btn btn-lg btn-primary">
                        Get started
                    </a>
                }

            </div>
        </div>

        <div class="card">
            <div class="card-body">

                <div class="d-flex justify-content-between">
                    <div class="flex-fill">
                        <form method="get" class="card p-3 mb-4 shadow-sm">
                        </form>
                    </div>
                </div>

                <div class="mt-4">

<style>
    :root {
        --primary: #143f63;
        --primary-dark: #0f3350;
        --primary-light: #1d4f7c;
        --bg: #f4f8fc;
        --surface: #ffffff;
        --surface-soft: #eef4f9;
        --text: #1e293b;
        --muted: #64748b;
        --border: #d7e2ed;
        --white: #ffffff;
    }

    body {
        background: var(--bg);
        color: var(--text);
        overflow-x: hidden;
        scroll-behavior: smooth;
    }

    .page-shell {
        max-width: 1220px;
        margin: 0 auto;
        padding: 0 20px;
    }

    .section-space {
        padding: 90px 0;
    }

    /* ===== NAVBAR ===== */
    .topbar {
        position: fixed;
        inset: 0 0 auto 0;
        z-index: 999;
        background: var(--primary);
        border-bottom: 1px solid rgba(255,255,255,.08);
        box-shadow: 0 10px 30px rgba(0,0,0,.14);
    }

    .topbar-inner {
        height: 76px;
    }

    .brand-wrap {
        text-decoration: none;
    }

    .brand-logo {
        width: 54px;
        height: 54px;
        border-radius: 50%;
        object-fit: cover;
        background: #fff;
        padding: 4px;
        box-shadow: 0 6px 18px rgba(0,0,0,.18);
    }

    .brand-title {
        font-size: 1.4rem;
        font-weight: 800;
        color: #fff;
        margin: 0;
        line-height: 1;
    }

    .brand-sub {
        font-size: 13px;
        color: rgba(255,255,255,.72);
        margin-top: 6px;
    }

    .nav-link-soft {
        color: rgba(255,255,255,.82);
        text-decoration: none;
        font-weight: 600;
        transition: .2s;
    }

        .nav-link-soft:hover {
            color: #fff;
        }

    /* ===== BUTTONS ===== */
    .btn-primary-soft {
        background: linear-gradient(135deg, #1d4f7c 0%, #245f95 100%);
        color: #fff;
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 14px;
        padding: 13px 22px;
        font-weight: 700;
        text-decoration: none;
        transition: .25s;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

        .btn-primary-soft:hover {
            transform: translateY(-2px);
            color: #fff;
            box-shadow: 0 14px 30px rgba(20,63,99,.28);
        }

    .btn-outline-soft {
        border: 1.5px solid rgba(20,63,99,.25);
        color: var(--primary);
        background: rgba(255,255,255,.7);
        border-radius: 14px;
        padding: 13px 22px;
        text-decoration: none;
        font-weight: 700;
        transition: .25s;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

        .btn-outline-soft:hover {
            background: #eaf2fb;
            transform: translateY(-2px);
            color: var(--primary);
        }

    /* ===== HERO ===== */
    .hero {
        padding-top: 140px;
        padding-bottom: 90px;
    }

    .hero-grid {
        display: grid;
        grid-template-columns: 1.1fr .9fr;
        gap: 60px;
        align-items: center;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(20,63,99,.10);
        color: var(--primary);
        padding: 10px 16px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: .08em;
    }

    .hero-title {
        font-size: clamp(2.5rem, 5vw, 4.5rem);
        font-weight: 800;
        line-height: 1.08;
        margin: 24px 0;
        letter-spacing: -.03em;
        color: var(--text);
    }

        .hero-title .accent {
            color: var(--primary);
        }

    .hero-desc {
        color: var(--muted);
        font-size: 1.08rem;
        line-height: 1.8;
        max-width: 650px;
    }

    .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
        margin-top: 32px;
    }

    .hero-image-wrap {
        position: relative;
    }

    .hero-image {
        width: 100%;
        aspect-ratio: 1 / 1;
        object-fit: cover;
        border-radius: 36px;
        box-shadow: 0 30px 60px rgba(0,0,0,.12);
    }

    .floating-card {
        position: absolute;
        left: -20px;
        bottom: -20px;
        display: flex;
        align-items: center;
        gap: 14px;
        background: rgba(255,255,255,.95);
        backdrop-filter: blur(14px);
        padding: 18px 22px;
        border-radius: 20px;
        box-shadow: 0 16px 30px rgba(0,0,0,.12);
        border: 1px solid rgba(20,63,99,.12);
    }

    .floating-icon {
        width: 52px;
        height: 52px;
        border-radius: 14px;
        background: rgba(20,63,99,.10);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--primary);
        font-size: 1.4rem;
    }

    /* ===== COMMON SECTIONS ===== */
    .section-title {
        font-size: clamp(1.7rem, 3vw, 2.5rem);
        font-weight: 800;
        margin-bottom: 14px;
        letter-spacing: -.02em;
        color: var(--text);
    }

    .section-desc {
        color: var(--muted);
        max-width: 720px;
    }

    .bento-card {
        background: var(--surface);
        border-radius: 24px;
        padding: 32px;
        border: 1px solid rgba(215,226,237,.9);
        box-shadow: 0 10px 24px rgba(15,23,42,.05);
        transition: .25s;
        height: 100%;
    }

        .bento-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 20px 40px rgba(15,23,42,.08);
        }

    .service-icon {
        width: 58px;
        height: 58px;
        border-radius: 18px;
        background: rgba(20,63,99,.10);
        color: var(--primary);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        margin-bottom: 20px;
    }

    .chip {
        padding: 10px 16px;
        border-radius: 999px;
        background: rgba(20,63,99,.10);
        color: var(--primary);
        font-size: 12px;
        font-weight: 800;
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    /* ===== PROJECT ===== */
    .project-image {
        width: 100%;
        aspect-ratio: 16/9;
        object-fit: cover;
        border-radius: 18px;
        transition: .35s;
    }

    .project-card:hover .project-image {
        transform: scale(1.04);
    }

    /* ===== FOOTER ===== */
    .footer-main {
        background: var(--primary);
        color: #fff;
        padding: 80px 0 30px;
    }

    .footer-title {
        font-size: 26px;
        font-weight: 700;
        margin-bottom: 26px;
    }

    .footer-links {
        list-style: none;
        padding: 0;
        margin: 0;
    }

        .footer-links li {
            margin-bottom: 14px;
        }

        .footer-links a {
            color: rgba(255,255,255,.9);
            text-decoration: none;
            transition: .2s;
        }

            .footer-links a:hover {
                color: #8ec5ff;
            }

    .social-box {
        width: 48px;
        height: 48px;
        border: 1px solid rgba(255,255,255,.45);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        border-radius: 10px;
        transition: .2s;
        font-size: 20px;
    }

        .social-box:hover {
            background: rgba(255,255,255,.1);
            transform: translateY(-2px);
            color: #fff;
        }

    .footer-divider {
        height: 1px;
        background: rgba(255,255,255,.22);
        margin-top: 40px;
    }

    .footer-bottom {
        padding-top: 24px;
        display: flex;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 18px;
    }

    .footer-policy {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        align-items: center;
    }

        .footer-policy a {
            color: #fff;
            text-decoration: none;
        }

            .footer-policy a:hover {
                color: #8ec5ff;
            }

    /* ===== FLOATING CHAT ===== */
    .fab-chat {
        position: fixed;
        right: 24px;
        bottom: 24px;
        width: 58px;
        height: 58px;
        border-radius: 50%;
        background: var(--primary-dark);
        border: none;
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 20px 40px rgba(20,63,99,.28);
        z-index: 100;
        transition: .25s;
    }

        .fab-chat:hover {
            transform: scale(1.08);
            color: #fff;
        }

    /* ===== RESPONSIVE ===== */
    @@media(max-width:991px) {
        .hero-grid {
            grid-template-columns: 1fr;
        }

        .floating-card {
            left: 12px;
            bottom: 12px;
        }

        .footer-bottom {
            flex-direction: column;
        }
    }
</style>

<!-- ===== Top bar ===== -->
<nav class="topbar">
    <div class="page-shell topbar-inner d-flex align-items-center justify-content-between">
        <a class="brand" href="/">Freelancer Job Matching System</a>

        <div class="d-none d-md-flex align-items-center gap-4">
            <a class="nav-link-soft" href="#portfolio">Portfolio</a>
            <a class="nav-link-soft" href="#services">Services</a>
            <a class="nav-link-soft" href="#contact">Contact</a>
        </div>

        <div class="d-none d-md-block">
            @if (CurrentUser.IsAuthenticated)
            {
                <span class="me-2 text-muted">Xin chào, <strong>@CurrentUser.Name</strong></span>
            }
            else
            {
                <a href="/auth/login" class="btn-primary-soft">Get started</a>
            }
        </div>
    </div>
</nav>

<main>
    <!-- ===== Hero section ===== -->
