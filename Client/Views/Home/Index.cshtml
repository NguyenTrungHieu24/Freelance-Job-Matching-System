@inject IUserService CurrentUser

@{
    ViewData["Title"] = "Home";
    Layout = "_Layout";
}


<section class="content">
<div class="container-fluid p-0">

    <style>
            /* ===== RESET & BASE ===== */
            *, *::before, *::after {
                box-sizing: border-box;
            }

            :root {
                --brand: #f05a1a;
                --brand-dark: #d4440c;
                --brand-light: #fff1ec;
                --navy: #1a2e4a;
                --navy-mid: #253b5e;
                --bg: #f5f7fa;
                --surface: #ffffff;
                --border: #e4e9f0;
                --text: #1e2d3d;
                --muted: #6b7a8f;
                --green: #18a84c;
                --radius-sm: 8px;
                --radius-md: 14px;
                --radius-lg: 22px;
                --shadow-sm: 0 2px 8px rgba(0,0,0,.06);
                --shadow-md: 0 8px 24px rgba(0,0,0,.09);
                --shadow-lg: 0 20px 48px rgba(0,0,0,.12);
            }

            body {
                background: var(--bg);
                color: var(--text);
                scroll-behavior: smooth;
            }

            .fv-wrap {
                max-width: 1220px;
                margin: 0 auto;
                padding: 0 20px;
            }

            /* ===== TOPBAR ===== */
            .fv-topbar {
                position: fixed;
                inset: 0 0 auto 0;
                z-index: 900;
                background: var(--navy);
                box-shadow: 0 4px 20px rgba(0,0,0,.18);
            }

            .fv-topbar-inner {
                height: 68px;
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 24px;
            }

            .fv-brand {
                font-size: 1.35rem;
                font-weight: 800;
                color: #fff;
                text-decoration: none;
                white-space: nowrap;
                letter-spacing: -.01em;
            }

                .fv-brand span {
                    color: var(--brand);
                }

            .fv-nav {
                display: flex;
                align-items: center;
                gap: 6px;
            }

                .fv-nav a {
                    color: rgba(255,255,255,.82);
                    text-decoration: none;
                    font-weight: 600;
                    padding: 7px 14px;
                    border-radius: var(--radius-sm);
                    font-size: .93rem;
                    transition: .2s;
                }

                    .fv-nav a:hover {
                        color: #fff;
                        background: rgba(255,255,255,.1);
                    }

            .fv-nav-actions {
                display: flex;
                align-items: center;
                gap: 10px;
            }

            .btn-login {
                color: #fff;
                text-decoration: none;
                font-weight: 700;
                font-size: .9rem;
                padding: 8px 18px;
                border-radius: var(--radius-sm);
                border: 1.5px solid rgba(255,255,255,.35);
                transition: .2s;
            }

                .btn-login:hover {
                    background: rgba(255,255,255,.1);
                    color: #fff;
                }

            .btn-register {
                background: var(--brand);
                color: #fff;
                text-decoration: none;
                font-weight: 700;
                font-size: .9rem;
                padding: 8px 18px;
                border-radius: var(--radius-sm);
                border: none;
                transition: .2s;
            }

                .btn-register:hover {
                    background: var(--brand-dark);
                    color: #fff;
                    transform: translateY(-1px);
                }

            /* ===== HERO ===== */
            .fv-hero {
                margin-top: 68px;
                background: linear-gradient(135deg, var(--navy) 0%, var(--navy-mid) 60%, #1e3a5f 100%);
                padding: 72px 0 80px;
                position: relative;
                overflow: hidden;
            }

                .fv-hero::before {
                    content: '';
                    position: absolute;
                    inset: 0;
                    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Ccircle cx='30' cy='30' r='4'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
                    pointer-events: none;
                }

            .fv-hero-inner {
                position: relative;
                text-align: center;
            }

            .fv-hero-badge {
                display: inline-flex;
                align-items: center;
                gap: 8px;
                background: rgba(240,90,26,.18);
                color: #ffa07a;
                padding: 7px 16px;
                border-radius: 999px;
                font-size: .78rem;
                font-weight: 800;
                text-transform: uppercase;
                letter-spacing: .1em;
                margin-bottom: 20px;
            }

            .fv-hero h1 {
                font-size: clamp(1.9rem, 4vw, 3.4rem);
                font-weight: 800;
                color: #fff;
                line-height: 1.15;
                letter-spacing: -.02em;
                margin: 0 0 14px;
            }

                .fv-hero h1 span {
                    color: var(--brand);
                }

            .fv-hero-sub {
                color: rgba(255,255,255,.68);
                font-size: 1.05rem;
                max-width: 580px;
                margin: 0 auto 36px;
                line-height: 1.7;
            }

            /* Search bar */
            .fv-search-wrap {
                max-width: 720px;
                margin: 0 auto 28px;
                background: #fff;
                border-radius: var(--radius-md);
                display: flex;
                align-items: center;
                box-shadow: 0 16px 40px rgba(0,0,0,.22);
                overflow: hidden;
            }

            .fv-search-select {
                border: none;
                outline: none;
                background: var(--bg);
                color: var(--text);
                font-weight: 600;
                font-size: .9rem;
                padding: 0 14px;
                height: 58px;
                min-width: 140px;
                border-right: 1px solid var(--border);
                cursor: pointer;
                appearance: auto;
            }

            .fv-search-input {
                flex: 1;
                border: none;
                outline: none;
                padding: 0 18px;
                font-size: 1rem;
                color: var(--text);
                height: 58px;
                background: transparent;
            }

                .fv-search-input::placeholder {
                    color: var(--muted);
                }

            .fv-search-btn {
                background: var(--brand);
                color: #fff;
                border: none;
                height: 58px;
                padding: 0 28px;
                font-weight: 700;
                font-size: 1rem;
                cursor: pointer;
                transition: .2s;
                white-space: nowrap;
                display: flex;
                align-items: center;
                gap: 8px;
            }

                .fv-search-btn:hover {
                    background: var(--brand-dark);
                }

            /* Popular tags */
            .fv-tags {
                display: flex;
                flex-wrap: wrap;
                justify-content: center;
                gap: 8px;
                max-width: 640px;
                margin: 0 auto;
            }

            .fv-tag {
                background: rgba(255,255,255,.12);
                color: rgba(255,255,255,.82);
                padding: 5px 14px;
                border-radius: 999px;
                font-size: .82rem;
                font-weight: 600;
                text-decoration: none;
                transition: .2s;
            }

                .fv-tag:hover {
                    background: var(--brand);
                    color: #fff;
                }

            /* ===== STATS BAR ===== */
            .fv-stats {
                background: var(--surface);
                border-bottom: 1px solid var(--border);
                box-shadow: var(--shadow-sm);
            }

            .fv-stats-inner {
                display: flex;
                align-items: stretch;
            }

            .fv-stat {
                flex: 1;
                text-align: center;
                padding: 22px 16px;
                border-right: 1px solid var(--border);
            }

                .fv-stat:last-child {
                    border-right: none;
                }

            .fv-stat-num {
                font-size: 1.75rem;
                font-weight: 800;
                color: var(--brand);
                line-height: 1;
            }

            .fv-stat-label {
                font-size: .8rem;
                color: var(--muted);
                font-weight: 600;
                margin-top: 4px;
            }

            /* ===== CATEGORIES ===== */
            .fv-cats {
                padding: 64px 0 50px;
            }

            .fv-section-head {
                margin-bottom: 36px;
            }

                .fv-section-head h2 {
                    font-size: clamp(1.4rem, 2.5vw, 2rem);
                    font-weight: 800;
                    color: var(--text);
                    margin: 0 0 8px;
                    letter-spacing: -.02em;
                }

                .fv-section-head p {
                    color: var(--muted);
                    font-size: .95rem;
                    margin: 0;
                }

                .fv-section-head .fv-see-all {
                    color: var(--brand);
                    text-decoration: none;
                    font-weight: 700;
                    font-size: .9rem;
                }

                    .fv-section-head .fv-see-all:hover {
                        text-decoration: underline;
                    }

            .fv-cat-grid {
                display: grid;
                grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
                gap: 14px;
            }

            .fv-cat-card {
                background: var(--surface);
                border: 1px solid var(--border);
                border-radius: var(--radius-md);
                padding: 22px 14px;
                text-align: center;
                text-decoration: none;
                color: var(--text);
                transition: .22s;
                cursor: pointer;
            }

                .fv-cat-card:hover {
                    border-color: var(--brand);
                    color: var(--brand);
                    box-shadow: var(--shadow-md);
                    transform: translateY(-4px);
                }

            .fv-cat-icon {
                width: 50px;
                height: 50px;
                border-radius: 14px;
                background: var(--brand-light);
                color: var(--brand);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1.4rem;
                margin: 0 auto 12px;
                transition: .22s;
            }

            .fv-cat-card:hover .fv-cat-icon {
                background: var(--brand);
                color: #fff;
            }

            .fv-cat-name {
                font-size: .85rem;
                font-weight: 700;
                line-height: 1.3;
            }

            .fv-cat-count {
                font-size: .75rem;
                color: var(--muted);
                margin-top: 4px;
            }

            /* ===== JOBS SECTION ===== */
            .fv-jobs {
                padding: 56px 0;
                background: var(--bg);
            }

            .fv-job-grid {
                display: grid;
                grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
                gap: 18px;
            }

            .fv-job-card {
                background: var(--surface);
                border: 1px solid var(--border);
                border-radius: var(--radius-md);
                padding: 22px;
                transition: .22s;
                text-decoration: none;
                color: var(--text);
                display: flex;
                flex-direction: column;
                gap: 14px;
            }

                .fv-job-card:hover {
                    box-shadow: var(--shadow-md);
                    transform: translateY(-4px);
                    border-color: #c8d6e5;
                    color: var(--text);
                }

            .fv-job-header {
                display: flex;
                align-items: flex-start;
                gap: 14px;
            }

            .fv-job-logo {
                width: 52px;
                height: 52px;
                border-radius: 12px;
                border: 1px solid var(--border);
                object-fit: cover;
                flex-shrink: 0;
                background: var(--bg);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1.4rem;
                color: var(--muted);
            }

            .fv-job-title {
                font-size: 1rem;
                font-weight: 700;
                margin: 0 0 4px;
                line-height: 1.3;
            }

            .fv-job-company {
                font-size: .83rem;
                color: var(--muted);
                font-weight: 600;
            }

            .fv-job-desc {
                font-size: .88rem;
                color: var(--muted);
                line-height: 1.6;
                margin: 0;
            }

            .fv-job-footer {
                display: flex;
                align-items: center;
                justify-content: space-between;
                flex-wrap: wrap;
                gap: 8px;
            }

            .fv-job-tags {
                display: flex;
                flex-wrap: wrap;
                gap: 6px;
            }

            .fv-job-tag {
                background: var(--bg);
                color: var(--muted);
                border: 1px solid var(--border);
                padding: 3px 10px;
                border-radius: 999px;
                font-size: .75rem;
                font-weight: 600;
            }

            .fv-job-budget {
                font-size: .92rem;
                font-weight: 800;
                color: var(--green);
                white-space: nowrap;
            }

            .fv-job-meta {
                display: flex;
                align-items: center;
                justify-content: space-between;
                font-size: .78rem;
                color: var(--muted);
                border-top: 1px solid var(--border);
                padding-top: 12px;
                margin-top: 2px;
            }

            .fv-bid-badge {
                background: var(--brand-light);
                color: var(--brand);
                padding: 3px 10px;
                border-radius: 999px;
                font-size: .75rem;
                font-weight: 700;
            }

            /* ===== HOW IT WORKS ===== */
            .fv-how {
                padding: 72px 0;
                background: var(--surface);
            }

            .fv-how-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
                gap: 32px;
                margin-top: 48px;
            }

            .fv-step {
                text-align: center;
            }

            .fv-step-num {
                width: 60px;
                height: 60px;
                border-radius: 50%;
                background: var(--brand);
                color: #fff;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1.5rem;
                font-weight: 800;
                margin: 0 auto 18px;
                box-shadow: 0 8px 20px rgba(240,90,26,.3);
            }

            .fv-step h3 {
                font-size: 1.05rem;
                font-weight: 800;
                margin: 0 0 10px;
            }

            .fv-step p {
                color: var(--muted);
                font-size: .9rem;
                line-height: 1.7;
                margin: 0;
            }

            .fv-step-connector {
                display: flex;
                align-items: center;
                justify-content: center;
                color: var(--border);
                font-size: 1.5rem;
                padding-top: 30px;
            }

            /* ===== FREELANCERS ===== */
            .fv-freelancers {
                padding: 60px 0;
                background: var(--bg);
            }

            .fv-fl-grid {
                display: grid;
                grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
                gap: 18px;
            }

            .fv-fl-card {
                background: var(--surface);
                border: 1px solid var(--border);
                border-radius: var(--radius-md);
                padding: 24px 18px;
                text-align: center;
                transition: .22s;
                text-decoration: none;
                color: var(--text);
            }

                .fv-fl-card:hover {
                    box-shadow: var(--shadow-md);
                    transform: translateY(-4px);
                    color: var(--text);
                }

            .fv-fl-avatar {
                width: 72px;
                height: 72px;
                border-radius: 50%;
                object-fit: cover;
                border: 3px solid var(--brand-light);
                margin: 0 auto 12px;
                display: block;
                background: var(--bg);
                font-size: 2rem;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .fv-fl-name {
                font-size: .95rem;
                font-weight: 700;
                margin: 0 0 4px;
            }

            .fv-fl-title {
                font-size: .8rem;
                color: var(--muted);
                margin: 0 0 10px;
            }

            .fv-fl-stars {
                color: #f59e0b;
                font-size: .85rem;
            }

            .fv-fl-rate {
                font-size: .82rem;
                color: var(--green);
                font-weight: 700;
                margin-top: 6px;
            }

            .fv-fl-tag {
                display: inline-block;
                margin-top: 8px;
                background: var(--brand-light);
                color: var(--brand);
                padding: 3px 10px;
                border-radius: 999px;
                font-size: .73rem;
                font-weight: 700;
            }

            /* ===== CTA BANNER ===== */
            .fv-cta {
                background: linear-gradient(135deg, var(--brand) 0%, #ff7e40 100%);
                padding: 70px 0;
            }

            .fv-cta-inner {
                text-align: center;
            }

            .fv-cta h2 {
                font-size: clamp(1.6rem, 3vw, 2.4rem);
                font-weight: 800;
                color: #fff;
                margin: 0 0 14px;
            }

            .fv-cta p {
                color: rgba(255,255,255,.85);
                font-size: 1rem;
                margin: 0 0 32px;
            }

            .fv-cta-actions {
                display: flex;
                justify-content: center;
                gap: 14px;
                flex-wrap: wrap;
            }

            .btn-cta-white {
                background: #fff;
                color: var(--brand);
                font-weight: 800;
                padding: 14px 30px;
                border-radius: var(--radius-sm);
                border: none;
                text-decoration: none;
                font-size: 1rem;
                transition: .2s;
            }

                .btn-cta-white:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 10px 24px rgba(0,0,0,.2);
                    color: var(--brand-dark);
                }

            .btn-cta-outline {
                background: transparent;
                color: #fff;
                font-weight: 800;
                padding: 14px 30px;
                border-radius: var(--radius-sm);
                border: 2px solid rgba(255,255,255,.6);
                text-decoration: none;
                font-size: 1rem;
                transition: .2s;
            }

                .btn-cta-outline:hover {
                    background: rgba(255,255,255,.15);
                    color: #fff;
                }

            /* ===== FOOTER ===== */
            .fv-footer {
                background: var(--navy);
                color: rgba(255,255,255,.82);
                padding: 60px 0 24px;
            }

            .fv-footer-logo {
                font-size: 1.4rem;
                font-weight: 800;
                color: #fff;
                margin-bottom: 12px;
            }

                .fv-footer-logo span {
                    color: var(--brand);
                }

            .fv-footer-desc {
                font-size: .88rem;
                line-height: 1.7;
                max-width: 300px;
                margin-bottom: 20px;
            }

            .fv-footer h5 {
                color: #fff;
                font-weight: 700;
                font-size: .95rem;
                margin-bottom: 18px;
            }

            .fv-footer-links {
                list-style: none;
                padding: 0;
                margin: 0;
            }

                .fv-footer-links li {
                    margin-bottom: 10px;
                }

                .fv-footer-links a {
                    color: rgba(255,255,255,.7);
                    text-decoration: none;
                    font-size: .88rem;
                    transition: .2s;
                }

                    .fv-footer-links a:hover {
                        color: var(--brand);
                    }

            .fv-footer-socials {
                display: flex;
                gap: 10px;
            }

            .fv-social {
                width: 38px;
                height: 38px;
                border-radius: 8px;
                border: 1px solid rgba(255,255,255,.25);
                color: rgba(255,255,255,.75);
                display: flex;
                align-items: center;
                justify-content: center;
                text-decoration: none;
                font-size: .95rem;
                transition: .2s;
            }

                .fv-social:hover {
                    background: var(--brand);
                    border-color: var(--brand);
                    color: #fff;
                }

            .fv-footer-bottom {
                margin-top: 40px;
                padding-top: 20px;
                border-top: 1px solid rgba(255,255,255,.12);
                display: flex;
                justify-content: space-between;
                align-items: center;
                flex-wrap: wrap;
                gap: 12px;
                font-size: .82rem;
                color: rgba(255,255,255,.5);
            }

                .fv-footer-bottom a {
                    color: rgba(255,255,255,.5);
                    text-decoration: none;
                }

                    .fv-footer-bottom a:hover {
                        color: var(--brand);
                    }

            /* ===== RESPONSIVE ===== */
            @@media (max-width: 768px) {
                .fv-nav {
                    display: none;
                }

                .fv-job-grid {
                    grid-template-columns: 1fr;
                }

                .fv-stats-inner {
                    flex-wrap: wrap;
                }

                .fv-stat {
                    flex: 1 1 50%;
                    border-bottom: 1px solid var(--border);
                }

                .fv-search-select {
                    display: none;
                }
            }
        </style>


    <!-- ========== TOPBAR ========== -->
    <nav class="fv-topbar">
        <div class="fv-wrap fv-topbar-inner">
            <a href="/" class="fv-brand">Talent<span>Bridge</span></a>

            <div class="fv-nav">
                <a href="#categories">Danh mục</a>
                <a href="#projects">Dự án</a>
                <a href="#freelancers">Freelancers</a>
                <a href="#how">Cách thức</a>
            </div>

            <div class="fv-nav-actions">
                @if (CurrentUser.IsAuthenticated)
                {
                    <span style="color:rgba(255,255,255,.8);font-size:.9rem;font-weight:600">
                        Xin chào, <strong style="color:#fff">@CurrentUser.Name</strong>
                    </span>
                }
                else
                {
                    <a href="/auth/login" class="btn-login">Đăng nhập</a>
                    <a href="/auth/register" class="btn-register">Đăng ký</a>
                }
            </div>
        </div>
    </nav>

    <!-- ========== HERO ========== -->
    <section class="fv-hero">
        <div class="fv-wrap fv-hero-inner">
            <div class="fv-hero-badge">
                <i class="bi bi-lightning-charge-fill"></i>
                Vietnam's #1 Freelance Platform
            </div>

            <h1>
                Find The Right Projects —<br>
                Connect Fast, Pay Securely
            </h1>

            <p class="fv-hero-sub">
                Thousands of new projects every day. Connect employers and freelancers
                professionally in just a few minutes.
            </p>

            <!-- Search bar -->
            <div class="fv-search-wrap">
                <select class="fv-search-select">
                    <option>All Categories</option> 
                    <option>Programming</option>
                    <option>Design</option>
                    <option>Marketing</option>
                    <option>Content Writing</option>
                </select>

                <input class="fv-search-input" type="text"
                       placeholder="e.g. Logo Design, React Website, SEO Content..." />

                <button class="fv-search-btn">
                    <i class="bi bi-search"></i> Search
                </button>
            </div>

            <!-- Popular tags -->
            <div class="fv-tags">
                <span style="color:rgba(255,255,255,.5);font-size:.82rem;font-weight:600">Phổ biến:</span>
                <a href="#" class="fv-tag">React</a>
                <a href="#" class="fv-tag">Figma UI/UX</a>
                <a href="#" class="fv-tag">SEO</a>
                <a href="#" class="fv-tag">ASP.NET</a>
                <a href="#" class="fv-tag">Viết bài</a>
                <a href="#" class="fv-tag">Logo Design</a>
                <a href="#" class="fv-tag">Mobile App</a>
            </div>
        </div>
    </section>

    <!-- ========== STATS BAR ========== -->
    <div class="fv-stats">
        <div class="fv-wrap">
            <div class="fv-stats-inner">
                <div class="fv-stat">
                    <div class="fv-stat-num">18,400+</div>
                    <div class="fv-stat-label">Freelancer đã đăng ký</div>
                </div>
                <div class="fv-stat">
                    <div class="fv-stat-num">9,200+</div>
                    <div class="fv-stat-label">Dự án hoàn thành</div>
